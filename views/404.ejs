<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>404</title>

  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    html, body {
      width: 100%;
      height: 100%;
      overflow: hidden;
      background: black;
    }

    video {
      position: fixed;
      top: 0;
      left: 0;
      width: 100vw;
      height: 100vh;
      object-fit: cover;

      /* IMPORTANT */
      z-index: 9999;
    }
  </style>
</head>
<body>
  <video autoplay muted loop playsinline>
    <source src="/videos/404.mp4" type="video/mp4" />
  </video>
</body>
</html>
