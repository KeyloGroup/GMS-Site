<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title><%= workspace.name %> — Settings</title>
<script src="https://cdn.tailwindcss.com"></script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&family=Outfit:wght@600;800&display=swap" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">

<style>
body {
    background-color: #000;
    color: #fff;
    font-family: 'Inter', sans-serif;
}
h1,h2,h3,h4 { font-family: 'Outfit', sans-serif; }

.gradient-bg {
    background: radial-gradient(circle at 70% 50%, rgba(0, 51, 153, 0.5), rgba(0, 0, 0, 0.9) 70%),
                linear-gradient(135deg, rgba(0, 0, 64, 0.8), rgba(0, 0, 0, 0.95));
}
.glass {
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 22px;
}

.sidebar-link {
    display: flex; align-items: center; gap: .75rem;
    padding: .75rem .9rem; border-radius: .75rem;
    color: #9ca3af; font-weight: 500; transition: all 0.3s ease;
}
.sidebar-link:hover {
    background-color: rgba(37, 99, 235, 0.15);
    color: #60a5fa;
    transform: translateX(4px);
}
.sidebar-active {
    background-color: rgba(37, 99, 235, 0.25);
    color: #3b82f6;
    font-weight: 600;
}

.mini-link {
    display: flex; align-items: center; gap: .75rem;
    padding: .75rem; border-radius: .75rem;
    color: #9ca3af; cursor: pointer; transition: background-color .2s;
}
.mini-link:hover {
    background: rgba(37, 99, 235, 0.15);
    color: #60a5fa;
}
.mini-active {
    background: rgba(37, 99, 235, 0.25);
    color: #3b82f6;
    font-weight: 600;
}

.tab-content { display: none; }
.tab-content.active { display: block; }

/* Mini Sidebar height matches main sidebar */
.settings-sidebar-glass {
    border-radius: 0 22px 22px 0 !important;
    border-left: none !important;
    display: flex; flex-direction: column; flex-shrink:0;
}

.sidebar-link img {
    filter: brightness(0) invert(1);
}

/* ===== Fixed Toggle for Permissions ===== */
.toggle {
    position: relative;
    display: inline-flex;
    align-items: center;
    width: 52px;
    height: 28px;  /* consistent height */
    flex-shrink: 0;
}

/* Hide checkbox */
.toggle input {
    opacity: 0;
    width: 0;
    height: 0;
    position: absolute;
    pointer-events: none;
}

/* Slider track */
.slider {
    position: relative;
    width: 100%;
    height: 100%;
    background-color: rgba(71,85,105,0.8);
    border-radius: 999px;
    transition: background-color 200ms ease;
    border: 1px solid rgba(255,255,255,0.05);
    box-sizing: border-box;
}

/* Slider dot */
.slider:before {
    content: "";
    position: absolute;
    top: 50%;                  /* vertically center */
    left: 3px;                 /* starting offset */
    transform: translateY(-50%);
    width: 22px;               /* dot size */
    height: 22px;
    border-radius: 50%;
    background: #fff;
    box-shadow: 0 2px 6px rgba(0,0,0,0.3);
    transition: left 180ms cubic-bezier(.2,.9,.3,1);
}

/* Checked state */
.toggle input:checked + .slider {
    background-color: #3b82f6;
}

.toggle input:checked + .slider:before {
    left: calc(100% - 3px - 22px); /* right side offset */
}

/* Focus ring */
.toggle input:focus + .slider {
    box-shadow: 0 0 0 4px rgba(59,130,246,0.12);
}

/* ===== Permission row layout ===== */
.perm-row {
    display: flex;
    align-items: center;       /* vertical center */
    justify-content: space-between;
    gap: 1rem;
    padding: 0.75rem 1rem;
    border-radius: 0.75rem;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.08);
    margin-bottom: 0.5rem;
}

.perm-row label {
    flex: 1;
    line-height: 1.3;
    font-size: 0.9rem;
    color: #e2e8f0;
    margin-right: 1rem;
    word-break: break-word;
}

</style>
</head>

<body class="gradient-bg text-white flex min-h-screen">

<!-- Main Sidebar -->
<aside class="w-20 md:w-64 p-4 glass flex flex-col shadow-xl">
    <div class="flex flex-col items-center mb-10">
        <img src="<%= workspace.image %>" alt="Workspace Icon" class="w-14 h-14 rounded-full mb-2 shadow-md">
        <p class="text-gray-300 text-sm font-semibold text-center"><%= workspace.name %></p>
    </div>

    <div class="border-t border-gray-700 mb-4"></div>

    <nav class="flex flex-col gap-2 flex-1">
        <a href="/workspace/<%= workspace.id %>/" class="sidebar-link">
            <img src="/icons/icons8-home-48.png" class="w-5 h-5"> <span>Home</span>
        </a>
        <a href="#" class="sidebar-link">
            <img src="/icons/icons8-checked-box-50.png" class="w-5 h-5"> <span>Tasks</span>
        </a>
        <a href="#" class="sidebar-link">
            <img src="/icons/icons8-open-book-50.png" class="w-5 h-5"> <span>Logbook</span>
        </a>
        <a href="/workspace/<%= workspace.id %>/sessions" class="sidebar-link">
            <img src="/icons/icons8-calendar-50.png" class="w-5 h-5"> <span>Sessions</span>
        </a>
        <a href="#" class="sidebar-link">
            <img src="/icons/icons8-avatar-24.png" class="w-5 h-5"> <span>Staff</span>
        </a>
        <a href="/workspace/<%= workspace.id %>/activity" class="sidebar-link">
            <img src="/icons/icons8-clock-24.png" class="w-5 h-5"> <span>Activity</span>
        </a>
        <a href="#" class="sidebar-link">
            <img src="/icons/icons8-airplane-take-off-50.png" class="w-5 h-5"> <span>Leave</span>
        </a>
        <a href="#" class="sidebar-link">
            <img src="/icons/icons8-folder-50.png" class="w-5 h-5"> <span>Documents</span>
        </a>
    </nav>

    <div class="border-t border-gray-700 mt-4"></div>

    <a href="/workspace/<%= workspace.id %>/settings" class="sidebar-link mt-4 sidebar-active">
        <img src="/icons/icons8-settings-50.png" class="w-5 h-5">
        <span>Settings</span>
    </a>

    <div class="mt-6 flex items-center gap-3 p-2 glass rounded-xl">
        <img src="<%= userProfileURL %>" alt="Profile" class="w-10 h-10 rounded-full shadow">
        <div class="hidden md:block">
            <p class="text-sm font-semibold text-white"><%= user %></p>
            <p class="text-xs text-gray-400">Online</p>
        </div>
    </div>
</aside>

<!-- Settings Mini Sidebar + Main Content -->
<div class="flex flex-1 items-stretch">
    <aside class="w-64 p-4 glass flex-shrink-0 settings-sidebar-glass">
        <h2 class="font-bold text-xl mb-4 text-blue-400">Workspace Settings</h2>
        <ul class="space-y-1 flex-1">
            <li><button data-tab="general" class="mini-link mini-active"><i class="fa-solid fa-gear"></i> General</button></li>
            <li><button data-tab="features" class="mini-link"><i class="fa-solid fa-toggle-on"></i> Features</button></li>
            <li><button data-tab="api" class="mini-link"><i class="fa-solid fa-key"></i> API</button></li>
            <li><button data-tab="permissions" class="mini-link"><i class="fa-solid fa-users-gear"></i> Permissions</button></li>
        </ul>
    </aside>

    <main class="flex-1 p-8 overflow-y-auto space-y-10">
        <!-- General Settings -->
        <section id="general" class="tab-content active glass p-6">
            <h3 class="text-2xl font-semibold mb-6 text-blue-400">General Settings</h3>
            <form method="POST" action="/workspace/<%= workspace.id %>/settings/general" class="space-y-6">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <div>
                    <label class="block mb-2 font-medium text-gray-300">Workspace Name</label>
                    <input type="text" name="workspace_name" value="<%= workspace.name %>" 
                        class="glass px-4 py-2 rounded-xl text-white w-full border-none focus:ring-2 focus:ring-blue-400"/>
                </div>
                <button type="submit" class="btn-primary bg-blue-600 text-white px-5 py-2 rounded-xl hover:bg-blue-700 transition">Save Changes</button>
            </form>
        </section>

        <!-- Feature Toggles -->
        <section id="features" class="tab-content glass p-6">
            <h3 class="text-2xl font-semibold mb-6 text-blue-400">Feature Toggles</h3>
            <form method="POST" action="/workspace/<%= workspace.id %>/settings/features" class="space-y-6">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <div class="space-y-4">
                    <label class="flex items-center justify-between p-3 glass rounded-xl border border-white/10">
                        <span>Sessions <p class="text-sm text-gray-400">Enable time-tracked work periods.</p></span>
                        <label class="toggle">
                            <input type="checkbox" name="feature_training" checked>
                            <span class="slider"></span>
                        </label>
                    </label>
                    <label class="flex items-center justify-between p-3 glass rounded-xl border border-white/10">
                        <span>Logbook <p class="text-sm text-gray-400">Allow staff to record manual log entries.</p></span>
                        <label class="toggle">
                            <input type="checkbox" name="feature_shifts">
                            <span class="slider"></span>
                        </label>
                    </label>
                    <label class="flex items-center justify-between p-3 glass rounded-xl border border-white/10">
                        <span>Audit Logs <p class="text-sm text-gray-400">Track all administrative and system actions.</p></span>
                        <label class="toggle">
                            <input type="checkbox" name="feature_audit">
                            <span class="slider"></span>
                        </label>
                    </label>
                    <label class="flex items-center justify-between p-3 glass rounded-xl border border-white/10">
                        <span>Activity Tracking <p class="text-sm text-gray-400">Monitor staff presence and performance metrics.</p></span>
                        <label class="toggle">
                            <input type="checkbox" name="feature_activity">
                            <span class="slider"></span>
                        </label>
                    </label>
                    <label class="flex items-center justify-between p-3 glass rounded-xl border border-white/10">
                        <span>Documents <p class="text-sm text-gray-400">Manage shared files and reference materials.</p></span>
                        <label class="toggle">
                            <input type="checkbox" name="feature_documents">
                            <span class="slider"></span>
                        </label>
                    </label>
                </div>
                <button type="submit" class="mt-4 btn-primary bg-blue-600 text-white px-5 py-2 rounded-xl hover:bg-blue-700 transition">Update Features</button>
            </form>
        </section>

        <!-- API -->
        <section id="api" class="tab-content glass p-6">
            <h3 class="text-2xl font-semibold mb-6 text-blue-400">API Key Management</h3>
            <label class="block mb-2 font-medium text-gray-300">Current API Key</label>
            <div class="flex items-center gap-3">
                <input type="password" id="apiKey" value="<%= apiKeyDecrypted || '' %>" readonly
                class="glass px-4 py-2 rounded-xl flex-1 text-white border-none"/>

                <button type="button" onclick="toggleKey()" class="btn-secondary glass px-4 py-2 rounded-xl text-xl hover:bg-white/15 transition">
                    <i class="fa-solid fa-eye text-gray-400"></i>
                </button>
                <form method="POST" action="/workspace/<%= workspace.id %>/settings/api/regenerate">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button type="submit" class="bg-red-600 text-white px-4 py-2 rounded-xl hover:bg-red-700 transition">Re-generate</button>
                </form>
            </div>
        </section>

<!-- Permissions -->
<section id="permissions" class="tab-content glass p-6">
  <div class="flex justify-between items-center mb-6">
    <h3 class="text-2xl font-semibold text-blue-400">Role Permissions</h3>
    <button 
      id="openCreateRole" 
      class="bg-green-600 text-white px-5 py-2 rounded-xl hover:bg-green-700 transition font-semibold flex items-center gap-2"
    >
      <i class="fa-solid fa-plus"></i> Create Role
    </button>
  </div>

  <!-- Roles List -->
  <div id="rolesList" class="space-y-4">
    <% const roles = [
      {
        name: 'Admin', id: 'admin', permissions: {
          postWall: true, deleteWallPosts: true, pinWall: true,
          logbookAccess: true, manageLogbook: true,
          sessionsAccess: true, manageSessions: true, overrideSessions: true,
          manageStaff: true, overrideActivity: true,
          manageLOA: true, addDocuments: true, removeDocuments: true,
          settingsAccess: true, manageSettings: true
        }
      },
      {
        name: 'Staff', id: 'staff', permissions: {
          postWall: true, deleteWallPosts: false, pinWall: false,
          logbookAccess: true, manageLogbook: false,
          sessionsAccess: true, manageSessions: false, overrideSessions: false,
          manageStaff: false, overrideActivity: false,
          manageLOA: false, addDocuments: false, removeDocuments: false,
          settingsAccess: false, manageSettings: false
        }
      }
    ]; %>

    <% const permLabels = {
      postWall: 'Post on workspace wall',
      deleteWallPosts: 'Delete posts on workspace wall',
      pinWall: 'Pin messages on workspace wall',
      logbookAccess: 'Logbook access',
      manageLogbook: 'Manage logbook entries',
      sessionsAccess: 'Sessions Access',
      manageSessions: 'Create & Delete Sessions',
      overrideSessions: 'Override Sessions',
      manageStaff: 'Manage Staff',
      overrideActivity: 'Override Activity',
      manageLOA: 'Manage LOA',
      addDocuments: 'Add to documents',
      removeDocuments: 'Remove documents',
      settingsAccess: 'Settings access',
      manageSettings: 'Manage settings'
    }; %>

    <% roles.forEach(role => { %>
      <div class="glass rounded-2xl border border-white/10 overflow-hidden">
        <div class="flex items-center justify-between p-4 cursor-pointer" onclick="toggleRole('<%= role.id %>')">
          <div class="flex items-center gap-3">
            <i class="fa-solid fa-user-shield text-blue-400"></i>
            <div>
              <h4 class="text-lg font-semibold text-white"><%= role.name %></h4>
              <p class="text-xs text-gray-400">ID: <%= role.id %></p>
            </div>
          </div>
          <div class="flex items-center gap-4">
            <button 
              onclick="event.stopPropagation(); deleteRole('<%= role.id %>')" 
              class="text-gray-400 hover:text-red-500 transition"
              title="Delete Role"
            >
              <i class="fa-solid fa-trash"></i>
            </button>
            <i class="fa-solid fa-chevron-down text-gray-400 transition-transform" id="chevron-<%= role.id %>"></i>
          </div>
        </div>

        <!-- Permissions list -->
        <div id="role-perms-<%= role.id %>" class="hidden border-t border-white/10 p-4 bg-white/5">
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
            <% Object.entries(permLabels).forEach(([key, label]) => { %>
              <div class="flex items-center justify-between p-3 glass rounded-xl border border-white/10">
                <label for="<%= role.id + '-' + key %>" class="text-sm"><%= label %></label>
                <div class="toggle">
                  <input type="checkbox" id="<%= role.id + '-' + key %>" <%= role.permissions[key] ? 'checked' : '' %>>
                  <span class="slider"></span>
                </div>
              </div>
            <% }) %>
          </div>
          <button class="mt-4 bg-blue-600 text-white px-4 py-2 rounded-xl hover:bg-blue-700 transition">
            Save Changes
          </button>
        </div>
      </div>
    <% }) %>
  </div>

  <!-- Create Role Modal -->
  <div id="createRoleModal" class="fixed inset-0 bg-black/70 backdrop-blur-md hidden items-center justify-center z-50">
    <div class="glass p-6 rounded-2xl w-full max-w-lg border border-white/10 relative">
      <button 
        id="closeCreateRole" 
        class="absolute top-3 right-3 text-gray-400 hover:text-red-400 transition"
      >
        <i class="fa-solid fa-xmark text-xl"></i>
      </button>
      <h4 class="text-xl font-semibold mb-4 text-blue-400 flex items-center gap-2">
        <i class="fa-solid fa-user-shield"></i> Create New Role
      </h4>
      <form id="createRoleForm" class="space-y-4">
        <input 
          type="text" 
          name="role_name" 
          placeholder="Role Name (e.g. Supervisor)" 
          class="glass w-full px-4 py-2 rounded-xl text-white border-none focus:ring-2 focus:ring-blue-400"
          required
        >
        <input 
          type="text" 
          name="role_id" 
          placeholder="Role ID (e.g. supervisor_role)" 
          class="glass w-full px-4 py-2 rounded-xl text-white border-none focus:ring-2 focus:ring-blue-400"
          required
        >
        <button 
          type="submit" 
          class="w-full bg-green-600 text-white px-5 py-2 rounded-xl hover:bg-green-700 transition font-semibold flex items-center justify-center gap-2"
        >
          <i class="fa-solid fa-plus"></i> Add Role
        </button>
      </form>
    </div>
  </div>
</section>


    </main>
</div>

<script>
// Tabs
const links = document.querySelectorAll('.mini-link');
const sections = document.querySelectorAll('.tab-content');
links.forEach(link => {
    link.addEventListener('click', () => {
        links.forEach(l => l.classList.remove('mini-active'));
        sections.forEach(s => s.classList.remove('active'));
        link.classList.add('mini-active');
        document.getElementById(link.dataset.tab).classList.add('active');
    });
});

// API toggle
function toggleKey() {
    const field = document.getElementById("apiKey");
    const icon = event.currentTarget.querySelector('.fa-eye, .fa-eye-slash');
    if (field.type === "password") {
        field.type = "text";
        icon.classList.remove('fa-eye');
        icon.classList.add('fa-eye-slash');
    } else {
        field.type = "password";
        icon.classList.remove('fa-eye-slash');
        icon.classList.add('fa-eye');
    }
}

// Initial tab
document.addEventListener('DOMContentLoaded', () => {
    const initialLink = document.querySelector('.mini-link[data-tab="general"]');
    const initialSection = document.getElementById('general');
    if (initialLink) initialLink.classList.add('mini-active');
    if (initialSection) initialSection.classList.add('active');
});
</script>
<script src="https://kit.fontawesome.com/a076d05399.js" crossorigin="anonymous"></script>
<script>
  function toggleRole(id) {
    const panel = document.getElementById('role-perms-' + id);
    const icon = document.getElementById('chevron-' + id);
    if (!panel) return;
    panel.classList.toggle('hidden');
    icon.classList.toggle('rotate-180');
  }

  function deleteRole(id) {
    const card = document.querySelector(`[onclick="toggleRole('${id}')"]`)?.closest('.glass');
    if (!card) return;
    if (confirm('Are you sure you want to delete this role?')) {
      card.classList.add('opacity-0', 'scale-95', 'transition', 'duration-200');
      setTimeout(() => card.remove(), 200);
    }
  }

  const modal = document.getElementById('createRoleModal');
  document.getElementById('openCreateRole').addEventListener('click', () => {
    modal.classList.remove('hidden');
    modal.classList.add('flex');
  });
  document.getElementById('closeCreateRole').addEventListener('click', () => {
    modal.classList.add('hidden');
    modal.classList.remove('flex');
  });
  modal.addEventListener('click', e => {
    if (e.target === modal) {
      modal.classList.add('hidden');
      modal.classList.remove('flex');
    }
  });

  document.getElementById('createRoleForm').addEventListener('submit', e => {
    e.preventDefault();
    const form = e.target;
    const name = form.role_name.value.trim();
    const id = form.role_id.value.trim();
    if (!name || !id) return alert('Please fill out all fields.');

    const permissions = [
      'Post on workspace wall', 'Delete posts on workspace wall', 'Pin messages on workspace wall',
      'Logbook access', 'Manage logbook entries', 'Sessions Access', 'Create & Delete Sessions',
      'Override Sessions', 'Manage Staff', 'Override Activity', 'Manage LOA',
      'Add to documents', 'Remove documents', 'Settings access', 'Manage settings'
    ];

    const newRoleHTML = `
      <div class="glass rounded-2xl border border-white/10 overflow-hidden">
        <div class="flex items-center justify-between p-4 cursor-pointer" onclick="toggleRole('${id}')">
          <div class="flex items-center gap-3">
            <i class="fa-solid fa-user-shield text-blue-400"></i>
            <div>
              <h4 class="text-lg font-semibold text-white">${name}</h4>
              <p class="text-xs text-gray-400">ID: ${id}</p>
            </div>
          </div>
          <div class="flex items-center gap-4">
            <button onclick="event.stopPropagation(); deleteRole('${id}')" class="text-gray-400 hover:text-red-500 transition" title="Delete Role">
              <i class="fa-solid fa-trash"></i>
            </button>
            <i class="fa-solid fa-chevron-down text-gray-400 transition-transform" id="chevron-${id}"></i>
          </div>
        </div>
        <div id="role-perms-${id}" class="hidden border-t border-white/10 p-4 bg-white/5">
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
            ${permissions.map((p, i) => `
              <div class="flex items-center justify-between p-3 glass rounded-xl border border-white/10">
                <label for="${id}-perm${i}" class="text-sm">${p}</label>
                <div class="toggle">
                  <input type="checkbox" id="${id}-perm${i}">
                  <span class="slider"></span>
                </div>
              </div>
            `).join('')}
          </div>
          <button class="mt-4 bg-blue-600 text-white px-4 py-2 rounded-xl hover:bg-blue-700 transition">
            Save Changes
          </button>
        </div>
      </div>
    `;
    document.getElementById('rolesList').insertAdjacentHTML('beforeend', newRoleHTML);
    form.reset();
    modal.classList.add('hidden');
    modal.classList.remove('flex');
  });
</script>

</body>
</html>
