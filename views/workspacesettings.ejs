<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= workspace.name %> — Settings</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&family=Outfit:wght@600;800&display=swap" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">

  <style>
    body { font-family: 'Inter', sans-serif; }
    h1,h2,h3,h4 { font-family: 'Outfit', sans-serif; }
    .glass {
      background: rgba(255, 255, 255, 0.08);
      backdrop-filter: blur(20px) saturate(200%);
      -webkit-backdrop-filter: blur(20px) saturate(200%);
      border-radius: 20px;
      border: 1px solid rgba(255, 255, 255, 0.15);
      box-shadow: 0 8px 30px rgba(0, 0, 0, 0.1);
    }
    .sidebar-link {
      display: flex; align-items: center; gap: .75rem;
      padding: .75rem; border-radius: .5rem;
      color: #4b5563; transition: background-color .2s;
      cursor: pointer;
    }
    .sidebar-link:hover {
      background-color: rgba(168, 85, 247, 0.15);
      color: #6d28d9;
    }
    .sidebar-active {
      background-color: rgba(168, 85, 247, 0.25);
      color: #6d28d9; font-weight: 600;
    }
    .mini-link {
      display: flex; align-items: center; gap: .5rem;
      padding: .5rem .75rem; border-radius: .5rem;
      color: #4b5563; transition: background .2s;
      cursor: pointer;
    }
    .mini-link:hover {
      background: rgba(168, 85, 247, 0.1);
      color: #6d28d9;
    }
    .mini-active {
      background: rgba(168, 85, 247, 0.25);
      color: #6d28d9; font-weight: 600;
    }
    .tab-content { display: none; }
    .tab-content.active { display: block; }
    .sidebar-link img {
      filter: brightness(0) saturate(100%);
    }
    .sidebar-active img {
      filter: brightness(0) saturate(100%);
    }

    /* Toggle Switch */
    .toggle {
      position: relative;
      display: inline-block;
      width: 46px;
      height: 24px;
    }
    .toggle input {
      opacity: 0;
      width: 0;
      height: 0;
    }
    .slider {
      position: absolute;
      cursor: pointer;
      top: 0; left: 0; right: 0; bottom: 0;
      background-color: #ccc;
      transition: 0.4s;
      border-radius: 34px;
    }
    .slider:before {
      position: absolute;
      content: "";
      height: 18px; width: 18px;
      left: 3px; bottom: 3px;
      background-color: white;
      transition: 0.4s;
      border-radius: 50%;
    }
    input:checked + .slider {
      background-color: #7c3aed; /* purple-600 */
    }
    input:checked + .slider:before {
      transform: translateX(22px);
    }
  </style>
</head>
<body class="bg-gradient-to-br from-gray-50 via-purple-50 to-purple-100 text-slate-900 flex min-h-screen">

  <div class="flex flex-1">
    <!-- Workspace Sidebar -->
    <aside class="w-20 md:w-64 p-4 glass flex flex-col shadow-xl">
      <!-- Workspace Profile -->
      <div class="flex flex-col items-center mb-10">
        <img src="<%= workspace.image %>" alt="Workspace Profile" class="w-12 h-12 rounded-full mb-2">
        <p class="text-slate-600 text-sm font-semibold"><%= workspace.name %></p>
      </div>

      <div class="border-t border-purple-200 mb-4"></div>

      <nav class="flex flex-col gap-2 flex-1">
        <a href="#" class="sidebar-link">
          <img src="/icons/icons8-home-48.png" class="w-5 h-5">
          <span>Home</span>
        </a>
        <a href="#" class="sidebar-link">
          <img src="/icons/icons8-checked-box-50.png" class="w-5 h-5">
          <span>Tasks</span>
        </a>
        <a href="#" class="sidebar-link">
          <img src="/icons/icons8-open-book-50.png" class="w-5 h-5">
          <span>Logbook</span>
        </a>
        <a href="/workspace/<%= workspace.id %>/sessions" class="sidebar-link">
          <img src="/icons/icons8-calendar-50.png" class="w-5 h-5">
          <span>Sessions</span>
        </a>
        <a href="#" class="sidebar-link">
          <img src="/icons/icons8-avatar-24.png" class="w-5 h-5">
          <span>Staff</span>
        </a>
        <a href="#" class="sidebar-link">
          <img src="/icons/icons8-clock-24.png" class="w-5 h-5">
          <span>Activity</span>
        </a>
        <a href="#" class="sidebar-link">
          <img src="/icons/icons8-airplane-take-off-50.png" class="w-5 h-5">
          <span>Leave of Absence</span>
        </a>
        <a href="#" class="sidebar-link">
          <img src="/icons/icons8-folder-50.png" class="w-5 h-5">
          <span>Documents</span>
        </a>
      </nav>

      <div class="border-t border-purple-200 mt-4"></div>

      <a href="/workspace/<%= workspace.id %>/settings" class="sidebar-link mt-4 sidebar-active">
        <img src="/icons/icons8-settings-50.png" class="w-5 h-5">
        <span>Settings</span>
      </a>

      <!-- User Profile Section -->
      <div class="mt-6 flex items-center gap-3 p-2 glass rounded-lg">
        <img src="<%= userProfileURL %>" alt="Profile" class="w-10 h-10 rounded-full">
        <div class="hidden md:block">
          <p class="text-sm font-semibold text-slate-800"><%= user %></p>
          <p class="text-xs text-slate-500">Online</p>
        </div>
      </div>
    </aside>

    <!-- Settings Layout -->
    <div class="flex flex-1">
      <!-- Mini Sidebar -->
      <aside class="w-64 p-4 glass flex-shrink-0">
        <h2 class="font-bold text-lg mb-4 text-purple-800">Settings</h2>
        <ul class="space-y-2">
          <li><button data-tab="general" class="mini-link mini-active"><i class="fa-solid fa-gear"></i> General</button></li>
          <li><button data-tab="features" class="mini-link"><i class="fa-solid fa-toggle-on"></i> Features</button></li>
          <li><button data-tab="api" class="mini-link"><i class="fa-solid fa-key"></i> API</button></li>
          <li><button data-tab="permissions" class="mini-link"><i class="fa-solid fa-users-gear"></i> Permissions</button></li>
        </ul>
      </aside>

      <!-- Main Content -->
      <main class="flex-1 p-8 overflow-y-auto space-y-12">
        <!-- General -->
        <section id="general" class="tab-content active glass p-6">
          <h3 class="text-xl font-semibold mb-4 text-purple-800">General</h3>
          <form method="POST" action="/workspace/<%= workspace.id %>/settings/general" class="space-y-4">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <div>
              <label class="block mb-2 font-medium">Workspace Name</label>
              <input type="text" name="workspace_name" value="<%= workspace.name %>" class="border rounded-lg p-2 w-full"/>
            </div>
            <button type="submit" class="bg-purple-600 text-white px-4 py-2 rounded-lg">Save</button>
          </form>
        </section>

        <!-- Features -->
        <section id="features" class="tab-content glass p-6">
          <h3 class="text-xl font-semibold mb-4 text-purple-800">Features</h3>
          <form method="POST" action="/workspace/<%= workspace.id %>/settings/features" class="space-y-4">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">

            <label class="flex items-center justify-between">
              <span>Sessions</span>
              <label class="toggle">
                <input type="checkbox" name="feature_training" checked>
                <span class="slider"></span>
              </label>
            </label>

            <label class="flex items-center justify-between">
              <span>Logbook</span>
              <label class="toggle">
                <input type="checkbox" name="feature_shifts">
                <span class="slider"></span>
              </label>
            </label>

            <label class="flex items-center justify-between">
              <span>Audit Logs</span>
              <label class="toggle">
                <input type="checkbox" name="feature_audit">
                <span class="slider"></span>
              </label>
            </label>

            <label class="flex items-center justify-between">
              <span>Activity</span>
              <label class="toggle">
                <input type="checkbox" name="feature_audit">
                <span class="slider"></span>
              </label>
            </label>

            <label class="flex items-center justify-between">
              <span>Documents</span>
              <label class="toggle">
                <input type="checkbox" name="feature_audit">
                <span class="slider"></span>
              </label>
            </label>

            <button type="submit" class="mt-4 bg-purple-600 text-white px-4 py-2 rounded-lg">Update Features</button>
          </form>
        </section>

        <!-- API -->
        <section id="api" class="tab-content glass p-6">
          <h3 class="text-xl font-semibold mb-4 text-purple-800">API</h3>
          <label class="block mb-2 font-medium">API Key</label>
          <div class="flex items-center gap-2">
            <input type="password" id="apiKey" value="sk_live_1234-5678-XXXX" readonly class="border rounded-lg p-2 flex-1"/> //get api key route needed to be done here to get the api key and show it
            <button type="button" onclick="toggleKey()" class="glass px-3 py-2 rounded-lg">👁</button>
            <form method="POST" action="/workspace/<%= workspace.id %>/settings/api/regenerate">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button type="submit" class="bg-red-600 text-white px-3 py-2 rounded-lg">Re-generate</button>
            </form>
          </div>
        </section>

        <!-- Permissions -->
        <section id="permissions" class="tab-content glass p-6">
          <h3 class="text-xl font-semibold mb-4 text-purple-800">Permissions</h3>
          <div class="space-y-4">
            <div class="glass p-4">
              <h4 class="font-bold mb-2">Admin Role</h4>
              <ul class="list-disc list-inside mb-2 text-slate-600">
                <li>Manage Sessions</li>
                <li>Manage API</li>
                <li>Invite Members</li>
              </ul>
              <button class="bg-purple-600 text-white px-3 py-1 rounded-lg">Edit</button>
            </div>
            <div class="glass p-4">
              <h4 class="font-bold mb-2">Moderator Role</h4>
              <ul class="list-disc list-inside mb-2 text-slate-600">
                <li>Host Sessions</li>
                <li>View Audit Logs</li>
              </ul>
              <button class="bg-purple-600 text-white px-3 py-1 rounded-lg">Edit</button>
            </div>
          </div>
          <button class="mt-4 bg-green-600 text-white px-4 py-2 rounded-lg">+ Create Role</button>
        </section>
      </main>
    </div>
  </div>

  <script>
    // Toggle API Key visibility
    function toggleKey() {
      const field = document.getElementById("apiKey");
      field.type = field.type === "password" ? "text" : "password";
    }

    // Tab switching
    const links = document.querySelectorAll('.mini-link');
    const sections = document.querySelectorAll('.tab-content');
    links.forEach(link => {
      link.addEventListener('click', () => {
        links.forEach(l => l.classList.remove('mini-active'));
        sections.forEach(s => s.classList.remove('active'));
        link.classList.add('mini-active');
        document.getElementById(link.dataset.tab).classList.add('active');
      });
    });
  </script>
</body>
</html>
