<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title><%= workspace.name %> — Settings</title>
<script src="https://cdn.tailwindcss.com"></script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&family=Outfit:wght@600;800&display=swap" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
<style>
body {
  background-color: #0d0d0d;
  color: #fff;
  font-family: 'Inter', sans-serif;
  margin: 0;
  min-height: 100vh;
  overflow-x: hidden;
}
.dotted-bg {
  position: fixed;
  inset: 0;
  background-image: radial-gradient(#1a1a1a 1px, transparent 1px);
  background-size: 24px 24px;
  z-index: 0;
}
aside {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
}
.glass {
  background: rgba(15,15,15,0.75);
  backdrop-filter: blur(20px);
  border: 1px solid rgba(255,255,255,0.04);
  box-shadow: inset 0 0 8px rgba(255,255,255,0.02), 0 6px 20px rgba(0,0,0,0.4);
  transition: all 0.3s ease;
}
.settings-sidebar-glass {
  background: rgba(15,15,15,0.75);
  backdrop-filter: blur(20px);
  border-left: 1px solid rgba(255,255,255,0.05);
  box-shadow: inset 0 0 12px rgba(255,255,255,0.02);
}
.sidebar-link {
  display: flex;
  align-items: center;
  gap: .75rem;
  padding: .75rem .9rem;
  border-radius: .75rem;
  color: #a1a1aa;
  font-weight: 500;
  text-decoration: none;
  transition: all .25s ease;
}
.sidebar-link:hover {
  background-color: rgba(59,130,246,0.12);
  color: #60a5fa;
  transform: translateX(3px);
}
.sidebar-active {
  background-color: rgba(59,130,246,0.18);
  color: #3b82f6;
  font-weight: 600;
  box-shadow: 0 0 10px rgba(59,130,246,0.15);
}
.sidebar-link img { filter: brightness(0) invert(1); opacity: 0.9; }
.sidebar-link:hover img { opacity: 1; }
.mini-link {
  display: flex;
  align-items: center;
  gap: .75rem;
  padding: .75rem;
  border-radius: .75rem;
  color: #a1a1aa;
  cursor: pointer;
  transition: background-color .2s ease, color .2s ease;
}
.mini-link:hover { background: rgba(59,130,246,0.12); color: #60a5fa; }
.mini-active {
  background: rgba(59,130,246,0.18);
  color: #3b82f6;
  font-weight: 600;
  box-shadow: 0 0 10px rgba(59,130,246,0.15);
}
::-webkit-scrollbar { width: 8px; background: #111; }
::-webkit-scrollbar-thumb { background: #222; border-radius: 8px; }
@media (max-width: 900px) {
  .settings-sidebar-glass { display: none; }
}
</style>
</head>
<body class="text-white flex min-h-screen relative">
<div class="dotted-bg"></div>
<div class="flex flex-1 items-stretch z-10">
  <aside class="w-20 md:w-64 p-4 glass border-r border-gray-800">
    <div class="flex flex-col items-center mb-10">
      <img src="<%= workspace.image %>" alt="Workspace Icon" class="w-14 h-14 rounded-full mb-2 shadow-md">
      <p class="text-gray-300 text-sm font-semibold text-center break-words"><%= workspace.name %></p>
    </div>
    <div class="border-t border-gray-700 mb-4"></div>
    <nav class="flex flex-col gap-2 flex-1">
      <a href="/workspace/<%= workspace.id %>/" class="sidebar-link"><img src="/icons/icons8-home-48.png" class="w-5 h-5">Home</a>
      <a href="#" class="sidebar-link"><img src="/icons/icons8-checked-box-50.png" class="w-5 h-5">Tasks</a>
      <a href="#" class="sidebar-link"><img src="/icons/icons8-open-book-50.png" class="w-5 h-5">Logbook</a>
      <a href="/workspace/<%= workspace.id %>/sessions" class="sidebar-link"><img src="/icons/icons8-calendar-50.png" class="w-5 h-5">Sessions</a>
      <a href="#" class="sidebar-link"><img src="/icons/icons8-avatar-24.png" class="w-5 h-5">Staff</a>
      <a href="/workspace/<%= workspace.id %>/activity" class="sidebar-link"><img src="/icons/icons8-clock-24.png" class="w-5 h-5">Activity</a>
      <a href="#" class="sidebar-link"><img src="/icons/icons8-airplane-take-off-50.png" class="w-5 h-5">Leave</a>
      <a href="#" class="sidebar-link"><img src="/icons/icons8-folder-50.png" class="w-5 h-5">Documents</a>
    </nav>
    <div class="border-t border-gray-800 mt-4"></div>
    <a href="/workspace/<%= workspace.id %>/settings" class="sidebar-link sidebar-active mt-4">
      <img src="/icons/icons8-settings-50.png" class="w-5 h-5">Settings
    </a>
    <div class="mt-6 flex items-center gap-3 p-2 bg-black/30 rounded-xl hover:bg-black/50 transition-all">
      <img src="<%= userProfileURL %>" alt="Profile" class="w-10 h-10 rounded-full shadow">
      <div class="hidden md:block">
        <p class="text-sm font-semibold text-white"><%= user %></p>
        <p class="text-xs text-gray-400">Online</p>
      </div>
    </div>
  </aside>

  <aside class="w-64 p-4 settings-sidebar-glass border-l border-gray-800">
    <h2 class="font-bold text-xl mb-4 text-blue-400">Workspace Settings</h2>
    <ul class="space-y-1 flex-1">
      <li><button data-tab="general" class="mini-link mini-active"><i class="fa-solid fa-gear"></i> General</button></li>
      <li><button data-tab="features" class="mini-link"><i class="fa-solid fa-toggle-on"></i> Features</button></li>
      <li><button data-tab="api" class="mini-link"><i class="fa-solid fa-key"></i> API</button></li>
      <li><button data-tab="permissions" class="mini-link"><i class="fa-solid fa-users-gear"></i> Permissions</button></li>
    </ul>
  </aside>

  <main class="flex-1 p-8 overflow-y-auto space-y-10 relative z-10">
    <!-- Your existing content -->
  </main>
</div>
<script>
const links=document.querySelectorAll('.mini-link');
const sections=document.querySelectorAll('.tab-content');
links.forEach(link=>{
 link.addEventListener('click',()=>{
  links.forEach(l=>l.classList.remove('mini-active'));
  sections.forEach(s=>s.classList.remove('active'));
  link.classList.add('mini-active');
  document.getElementById(link.dataset.tab).classList.add('active');
 });
});
</script>
</body>
</html>
