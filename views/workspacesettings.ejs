<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title><%= workspace.name %> — Settings</title>
<script src="https://cdn.tailwindcss.com"></script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&family=Outfit:wght@600;800&display=swap" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
<style>
body {
    background-color: #0d0d0d;
    color: #fff;
    font-family: 'Inter', sans-serif;
    min-height: 100vh;
    min-width: 100vw;
    margin: 0;
    padding: 0;
    overflow-x: hidden;
    position: relative;
}
.dotted-bg {
    position: fixed;
    inset: 0;
    background-image: radial-gradient(#222 1px, transparent 1px);
    background-size: 24px 24px;
    z-index: 0;
}
.dotted-bg::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(#1a1a1a 1px, transparent 1px);
    background-size: 24px 24px;
    opacity: 0.5;
    pointer-events: none;
}
h1,h2,h3,h4 { font-family: 'Outfit', sans-serif; }
.glass {
    background: rgba(24, 24, 24, 0.74);
    backdrop-filter: blur(16px);
    border-radius: 22px;
    border: 1px solid #232323;
    box-shadow: 0 8px 30px rgba(0,0,0,0.30);
    z-index: 1;
}
.sidebar {
    width: 84px;
    min-width: 84px;
    background: rgba(24, 24, 24, 0.9);
    border-right: 1px solid #18181b;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 1.5rem 0.5rem;
    height: 100vh;
    position: sticky;
    top: 0;
    left: 0;
    z-index: 30;
}
.sidebar .workspace-icon {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    margin-bottom: 1.2rem;
    box-shadow: 0 2px 16px #23232360;
    object-fit: cover;
    border: 2px solid #222;
}
.sidebar .workspace-name {
    color: #a3a3a3;
    font-size: 0.95rem;
    font-weight: 600;
    text-align: center;
    margin-bottom: 2.2rem;
    word-break: break-word;
}
.sidebar .sidebar-menu {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    width: 100%;
}
.sidebar .sidebar-link {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    padding: 0.8rem 0 0.5rem 0;
    border-radius: 1rem;
    color: #a3a3a3;
    font-weight: 500;
    font-size: 0.93rem;
    background: none;
    border: none;
    outline: none;
    transition: background 0.18s, color 0.16s, box-shadow 0.12s;
    cursor: pointer;
    text-decoration: none;
}
.sidebar .sidebar-link i, .sidebar .sidebar-link img {
    width: 26px;
    height: 26px;
    display: block;
    margin: 0 auto;
    filter: brightness(0) invert(1);
}
.sidebar .sidebar-link.active, .sidebar .sidebar-link:focus {
    background: rgba(37, 99, 235, 0.16);
    color: #60a5fa;
}
.sidebar .sidebar-link:hover {
    background: rgba(37, 99, 235, 0.14);
    color: #3b82f6;
    box-shadow: 0 2px 8px #1e3a8a20;
    transform: translateY(-2px) scale(1.03);
}
.sidebar .sidebar-link span {
    font-size: 0.75rem;
    font-weight: 500;
    margin-top: 2px;
    letter-spacing: 0.01em;
    display: block;
}
.sidebar .sidebar-footer {
    margin-top: 2.5rem;
    padding: 0.6rem 0;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
}
.sidebar .sidebar-footer .sidebar-link {
    margin-bottom: 0.7rem;
}
.sidebar .profile {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.5rem;
    padding: 1rem 0.2rem 0.1rem 0.2rem;
    border-radius: 1rem;
    background: rgba(37, 99, 235, 0.11);
    width: 100%;
}
.sidebar .profile img {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    box-shadow: 0 2px 10px #23232340;
    border: 1.5px solid #222;
}
.sidebar .profile .user-name {
    color: #fff;
    font-size: 0.92rem;
    font-weight: 600;
    margin-bottom: 0px;
    margin-top: 2px;
}
.sidebar .profile .user-status {
    font-size: 0.73rem;
    color: #60a5fa;
    letter-spacing: 0.01em;
}
.settings-sidebar-glass {
    border-radius: 0 22px 22px 0 !important;
    border-left: none !important;
    display: flex;
    flex-direction: column;
    flex-shrink: 0;
    height: 100vh;
    position: sticky;
    top: 0;
    left: 84px;
    background: rgba(24, 24, 24, 0.74);
    z-index: 10;
}
.mini-link {
    display: flex; align-items: center; gap: .75rem;
    padding: .75rem; border-radius: .75rem;
    color: #9ca3af; cursor: pointer; transition: background-color .2s;
    text-decoration: none;
}
.mini-link:hover {
    background: rgba(37, 99, 235, 0.15);
    color: #60a5fa;
}
.mini-active {
    background: rgba(37, 99, 235, 0.25);
    color: #3b82f6;
    font-weight: 600;
}
.tab-content { display: none; }
.tab-content.active { display: block; }
.toggle {
    position: relative;
    display: inline-flex;
    align-items: center;
    width: 52px;
    height: 28px;
    flex-shrink: 0;
}
.toggle input {
    opacity: 0;
    width: 0;
    height: 0;
    position: absolute;
    pointer-events: none;
}
.slider {
    position: relative;
    width: 100%;
    height: 100%;
    background-color: rgba(71,85,105,0.8);
    border-radius: 999px;
    transition: background-color 200ms ease;
    border: 1px solid rgba(255,255,255,0.05);
    box-sizing: border-box;
}
.slider:before {
    content: "";
    position: absolute;
    top: 50%;
    left: 3px;
    transform: translateY(-50%);
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: #fff;
    box-shadow: 0 2px 6px rgba(0,0,0,0.3);
    transition: left 180ms cubic-bezier(.2,.9,.3,1);
}
.toggle input:checked + .slider {
    background-color: #3b82f6;
}
.toggle input:checked + .slider:before {
    left: calc(100% - 3px - 22px);
}
.toggle input:focus + .slider {
    box-shadow: 0 0 0 4px rgba(59,130,246,0.12);
}
::-webkit-scrollbar { width: 8px; background: #181818; }
::-webkit-scrollbar-thumb { background: #1a1a1a; border-radius: 8px; }
@media (max-width: 1100px) {
    .settings-sidebar-glass { display: none; }
}
@media (max-width: 800px) {
    main { padding: 1.2rem !important; }
    .glass { padding: 1.2rem 0.7rem; }
    .sidebar { min-width: 56px !important; width: 56px !important; }
}
@media (max-width: 600px) {
    .glass { padding: 1rem 0.4rem; }
    .sidebar { min-width: 44px !important; width: 44px !important; }
}
</style>
</head>

<body class="dotted-bg text-white flex min-h-screen">

<aside class="sidebar">
    <img src="<%= workspace.image %>" alt="Workspace Icon" class="workspace-icon">
    <div class="workspace-name"><%= workspace.name %></div>
    <nav class="sidebar-menu">
        <a href="/workspace/<%= workspace.id %>/" class="sidebar-link"><img src="/icons/icons8-home-48.png"><span>Home</span></a>
        <a href="#" class="sidebar-link"><img src="/icons/icons8-checked-box-50.png"><span>Tasks</span></a>
        <a href="#" class="sidebar-link"><img src="/icons/icons8-open-book-50.png"><span>Logbook</span></a>
        <a href="/workspace/<%= workspace.id %>/sessions" class="sidebar-link"><img src="/icons/icons8-calendar-50.png"><span>Sessions</span></a>
        <a href="#" class="sidebar-link"><img src="/icons/icons8-avatar-24.png"><span>Staff</span></a>
        <a href="/workspace/<%= workspace.id %>/activity" class="sidebar-link"><img src="/icons/icons8-clock-24.png"><span>Activity</span></a>
        <a href="#" class="sidebar-link"><img src="/icons/icons8-airplane-take-off-50.png"><span>Leave</span></a>
        <a href="#" class="sidebar-link"><img src="/icons/icons8-folder-50.png"><span>Documents</span></a>
        <a href="/workspace/<%= workspace.id %>/settings" class="sidebar-link active"><img src="/icons/icons8-settings-50.png"><span>Settings</span></a>
    </nav>
    <div class="sidebar-footer">
        <div class="profile">
            <img src="<%= userProfileURL %>" alt="Profile">
            <div class="user-name"><%= user %></div>
            <div class="user-status">Online</div>
        </div>
    </div>
</aside>

<div class="flex flex-1 items-stretch min-h-screen">
    <aside class="w-64 p-4 glass settings-sidebar-glass">
        <h2 class="font-bold text-xl mb-4 text-blue-400">Workspace Settings</h2>
        <ul class="space-y-1 flex-1">
            <li><button data-tab="general" class="mini-link mini-active"><i class="fa-solid fa-gear"></i> General</button></li>
            <li><button data-tab="features" class="mini-link"><i class="fa-solid fa-toggle-on"></i> Features</button></li>
            <li><button data-tab="api" class="mini-link"><i class="fa-solid fa-key"></i> API</button></li>
            <li><button data-tab="permissions" class="mini-link"><i class="fa-solid fa-users-gear"></i> Permissions</button></li>
        </ul>
    </aside>

    <main class="flex-1 p-8 overflow-y-auto space-y-10">
        <!-- ... Main Content as before ... -->
        <!-- The rest of your HTML (General / Features / API / Permissions, etc) goes here, unchanged -->
        <!-- ... -->
    </main>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
    const links = document.querySelectorAll('.mini-link');
    const sections = document.querySelectorAll('.tab-content');
    links.forEach(link => {
        link.addEventListener('click', () => {
            links.forEach(l => l.classList.remove('mini-active'));
            sections.forEach(s => s.classList.remove('active'));
            link.classList.add('mini-active');
            document.getElementById(link.dataset.tab).classList.add('active');
        });
    });
    const initialLink = document.querySelector('.mini-link[data-tab="general"]');
    const initialSection = document.getElementById('general');
    if (initialLink) initialLink.classList.add('mini-active');
    if (initialSection) initialSection.classList.add('active');
    const modal = document.getElementById('createRoleModal');
    if (modal) {
        document.getElementById('openCreateRole').addEventListener('click', () => {
            modal.classList.remove('hidden');
            modal.classList.add('flex');
        });
        document.getElementById('closeCreateRole').addEventListener('click', () => {
            modal.classList.add('hidden');
            modal.classList.remove('flex');
        });
        modal.addEventListener('click', e => {
            if (e.target === modal) {
                modal.classList.add('hidden');
                modal.classList.remove('flex');
            }
        });
        document.getElementById('createRoleForm').addEventListener('submit', e => {
            e.preventDefault();
            const form = e.target;
            const name = form.role_name.value.trim();
            const id = form.role_id.value.trim();
            if (!name || !id) return alert('Please fill out all fields.');
            const permissions = [
              'Post on workspace wall', 'Delete posts on workspace wall', 'Pin messages on workspace wall',
              'Logbook access', 'Manage logbook entries', 'Sessions Access', 'Create & Delete Sessions',
              'Override Sessions', 'Manage Staff', 'Override Activity', 'Manage LOA',
              'Add to documents', 'Remove documents', 'Settings access', 'Manage settings'
            ];
            const newRoleHTML = `
              <div class="glass rounded-2xl border border-white/10 overflow-hidden">
                <div class="flex items-center justify-between p-4 cursor-pointer" onclick="toggleRole('${id}')">
                  <div class="flex items-center gap-3">
                    <i class="fa-solid fa-user-shield text-blue-400"></i>
                    <div>
                      <h4 class="text-lg font-semibold text-white">${name}</h4>
                      <p class="text-xs text-gray-400">ID: ${id}</p>
                    </div>
                  </div>
                  <div class="flex items-center gap-4">
                    <button onclick="event.stopPropagation(); deleteRole('${id}')" class="text-gray-400 hover:text-red-500 transition" title="Delete Role">
                      <i class="fa-solid fa-trash"></i>
                    </button>
                    <i class="fa-solid fa-chevron-down text-gray-400 transition-transform" id="chevron-${id}"></i>
                  </div>
                </div>
                <div id="role-perms-${id}" class="hidden border-t border-white/10 p-4 bg-white/5">
                  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
                    ${permissions.map((p, i) => `
                      <div class="flex items-center justify-between p-3 glass rounded-xl border border-white/10">
                        <label for="${id}-perm${i}" class="text-sm">${p}</label>
                        <div class="toggle">
                          <input type="checkbox" id="${id}-perm${i}">
                          <span class="slider"></span>
                        </div>
                      </div>
                    `).join('')}
                  </div>
                  <button class="mt-4 bg-blue-600 text-white px-4 py-2 rounded-xl hover:bg-blue-700 transition">
                    Save Changes
                  </button>
                </div>
              </div>
            `;
            document.getElementById('rolesList').insertAdjacentHTML('beforeend', newRoleHTML);
            form.reset();
            modal.classList.add('hidden');
            modal.classList.remove('flex');
        });
    }
});
function toggleKey() {
    const field = document.getElementById("apiKey");
    const icon = event.currentTarget.querySelector('.fa-eye, .fa-eye-slash');
    if (field.type === "password") {
        field.type = "text";
        icon.classList.remove('fa-eye');
        icon.classList.add('fa-eye-slash');
    } else {
        field.type = "password";
        icon.classList.remove('fa-eye-slash');
        icon.classList.add('fa-eye');
    }
}
function toggleRole(id) {
    const panel = document.getElementById('role-perms-' + id);
    const icon = document.getElementById('chevron-' + id);
    if (!panel) return;
    panel.classList.toggle('hidden');
    icon.classList.toggle('rotate-180');
}
function deleteRole(id) {
    const card = document.querySelector(`[onclick="toggleRole('${id}')"]`)?.closest('.glass');
    if (!card) return;
    if (confirm('Are you sure you want to delete this role?')) {
        card.classList.add('opacity-0', 'scale-95', 'transition', 'duration-200');
        setTimeout(() => card.remove(), 200);
    }
}
</script>
<script src="https://kit.fontawesome.com/a076d05399.js" crossorigin="anonymous"></script>
</body>
</html>
