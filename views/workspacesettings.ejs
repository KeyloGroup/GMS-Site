<!DOCTYPE html>
<html lang="en" class="dark">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title><%= workspace?.name || 'Workspace' %> Settings</title>

<script src="https://cdn.tailwindcss.com"></script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">

<script>
  tailwind.config = {
    darkMode: 'class',
    theme: {
      extend: {
        fontFamily: { sans: ['Inter', 'sans-serif'] },
        colors: {
          background: '#000',
          surface: '#0a0a0a',
          border: '#1f1f1f'
        }
      }
    }
  }
</script>

<style>
body { background:#000; color:#e5e5e5; font-family:Inter; }
.glass { background:#0a0a0a; border:1px solid #1f1f1f; }
.sidebar-item { transition:all .2s ease; }
.sidebar-item:hover { background:#111; }
.sidebar-active { background:#111; color:white; }
.toggle { position:relative;width:44px;height:24px; }
.toggle input { display:none; }
.slider {
  position:absolute;inset:0;border-radius:999px;background:#222;
}
.slider:before {
  content:"";position:absolute;width:18px;height:18px;background:white;border-radius:50%;top:3px;left:3px;transition:.2s;
}
.toggle input:checked + .slider { background:#2563eb; }
.toggle input:checked + .slider:before { transform:translateX(20px); }
</style>
</head>

<body class="flex min-h-screen">

<!-- Sidebar -->
<aside class="w-64 glass p-4 flex flex-col">
  <div class="mb-6">
    <p class="text-lg font-semibold"><%= workspace?.name || 'Workspace' %></p>
  </div>

  <nav class="space-y-1 text-sm">
    <button data-tab="general" class="sidebar-item sidebar-active w-full text-left px-3 py-2 rounded-lg">General</button>
    <button data-tab="activity" class="sidebar-item w-full text-left px-3 py-2 rounded-lg">Activity Tracking</button>
    <button data-tab="roles" class="sidebar-item w-full text-left px-3 py-2 rounded-lg">Roles</button>
    <button data-tab="sessions" class="sidebar-item w-full text-left px-3 py-2 rounded-lg">Sessions</button>
  </nav>
</aside>

<!-- Main -->
<main class="flex-1 p-8 space-y-8">

<!-- GENERAL -->
<section id="general" class="tab">
  <h1 class="text-2xl font-semibold mb-6">General</h1>

  <div class="glass p-6 rounded-xl space-y-4 max-w-xl">
    <input type="text" value="<%= workspace?.name %>" class="w-full bg-black border border-border px-4 py-2 rounded-lg">
    <input type="text" value="<%= workspace?.image %>" class="w-full bg-black border border-border px-4 py-2 rounded-lg">
    <button class="bg-white text-black px-4 py-2 rounded-lg">Save</button>
  </div>
</section>

<!-- ACTIVITY -->
<section id="activity" class="tab hidden">
  <h1 class="text-2xl font-semibold mb-6">Activity Tracking</h1>

  <button class="mb-6 bg-white text-black px-4 py-2 rounded-lg">
    <i class="fa fa-download mr-2"></i>Download Loader
  </button>

  <div class="glass rounded-xl divide-y divide-border max-w-xl">
    <% const roles = ['Member','Hotel Visitor','Partnership Rep','Trainee','Junior','Restaurant','Senior Leader','Team Leader','Supervisor','Manager']; %>

    <% roles.forEach((r,i)=>{ %>
      <div class="flex items-center justify-between px-4 py-3">
        <span><%= r %></span>
        <label class="toggle">
          <input type="checkbox" <%= i>5 ? 'checked':'' %> >
          <span class="slider"></span>
        </label>
      </div>
    <% }) %>
  </div>
</section>

<!-- ROLES -->
<section id="roles" class="tab hidden">
  <h1 class="text-2xl font-semibold mb-6">Roles</h1>

  <div class="glass p-6 rounded-xl">
    <p class="text-sm text-gray-400">Role management coming here.</p>
  </div>
</section>

<!-- SESSIONS -->
<section id="sessions" class="tab hidden">
  <h1 class="text-2xl font-semibold mb-6">Sessions</h1>

  <div class="glass p-6 rounded-xl">
    <p class="text-sm text-gray-400">Session settings coming here.</p>
  </div>
</section>

</main>

<script>
const tabs = document.querySelectorAll('[data-tab]');
const sections = document.querySelectorAll('.tab');

tabs.forEach(btn=>{
  btn.onclick = ()=>{
    tabs.forEach(b=>b.classList.remove('sidebar-active'));
    sections.forEach(s=>s.classList.add('hidden'));

    btn.classList.add('sidebar-active');
    document.getElementById(btn.dataset.tab).classList.remove('hidden');
  }
});
</script>

</body>
</html>
