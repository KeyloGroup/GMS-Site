<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Keylo — The Next Chapter</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">
  <link rel="icon" href="/assets/keylo-logo.png" />

  <style>
    body {
      background-color: #0d0d0d;
      color: #fff;
      font-family: 'Inter', sans-serif;
      overflow-x: hidden;
    }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(25px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .animate-fadeUp { animation: fadeUp 0.8s ease forwards; }
    .delay-1 { animation-delay: 0.2s; }
    .delay-2 { animation-delay: 0.4s; }
    .delay-3 { animation-delay: 0.6s; }

    .btn-primary {
      background-color: #fff;
      color: #000;
      font-weight: 600;
      border-radius: 8px;
      transition: all 0.2s ease;
    }
    .btn-primary:hover { background-color: #eaeaea; }

    .btn-secondary {
      background-color: transparent;
      color: #fff;
      border: 1px solid #333;
      font-weight: 600;
      border-radius: 8px;
      transition: all 0.2s ease;
    }
    .btn-secondary:hover {
      border-color: #555;
      background-color: #111;
    }

    header {
      background: rgba(13, 13, 13, 0.9);
      backdrop-filter: blur(8px);
      border-bottom: 1px solid #1a1a1a;
    }

    .divider { border-top: 1px solid #1a1a1a; }

    .dotted-bg {
      position: relative;
      background-image: radial-gradient(#222 1px, transparent 1px);
      background-size: 24px 24px;
    }
    .dotted-bg::before {
      content: "";
      position: absolute;
      inset: 0;
      background: radial-gradient(#1a1a1a 1px, transparent 1px);
      background-size: 24px 24px;
      opacity: 0.5;
      pointer-events: none;
      z-index: 0;
    }

    .glass {
      background: rgba(255, 255, 255, 0.05);
      backdrop-filter: blur(10px);
      border: 1px solid #1a1a1a;
      border-radius: 18px;
    }
  </style>
</head>

<body class="text-white min-h-screen flex flex-col">
  <!-- Header -->
  <header class="fixed top-0 w-full z-50">
    <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-full overflow-hidden border border-[#1c1c1c]">
          <img src="<%= typeof userProfileURL !== 'undefined' ? userProfileURL : '/assets/keylo-logo.png' %>" 
               alt="Profile"
               class="w-full h-full object-cover">
        </div>
        <h2 class="text-sm text-gray-400">Welcome, <span class="text-white font-semibold"><%= typeof user !== 'undefined' ? user : 'Guest' %></span></h2>
      </div>
      <a href="/launch" class="text-lg font-bold tracking-tight absolute left-1/2 transform -translate-x-1/2">Keylo</a>
      <a href="/logout" class="btn-secondary px-4 py-2 text-sm">Sign Out</a>
    </div>
  </header>

  <!-- Hero -->
  <section class="min-h-screen flex flex-col justify-center items-center text-center px-6 animate-fadeUp pt-28 dotted-bg">
    <div class="max-w-3xl relative z-10">
      <h1 class="text-5xl sm:text-6xl font-extrabold mb-6 leading-tight tracking-tight">
        The Next Chapter of <span class="text-gray-300">Keylo</span>
      </h1>
      <p class="text-gray-400 text-lg max-w-xl mx-auto mb-8">
        Something new is on the horizon. Smarter tools, deeper analytics, and seamless automation for your Roblox community.
      </p>
      <p class="text-gray-500 font-medium mb-12">
        Expected Launch: <span class="text-white font-semibold">N.A</span>
      </p>
    </div>
  </section>

  <div class="divider"></div>

  <!-- Highlights -->
  <section class="py-24 animate-fadeUp delay-1">
    <div class="max-w-6xl mx-auto px-6 grid md:grid-cols-3 gap-8 relative z-10">
      <div class="bg-[#111] p-10 rounded-2xl text-center border border-[#1c1c1c]">
        <h3 class="text-2xl font-semibold mb-3">🚀 Beta Access</h3>
        <p class="text-gray-400 mb-6">
          Be among the first to explore Keylo’s newest features. Join the beta and help shape the future.
        </p>
        <a href="#" class="btn-secondary px-6 py-3 inline-block">Closed</a>
      </div>

      <div class="bg-[#111] p-10 rounded-2xl text-center border border-[#1c1c1c]">
        <h3 class="text-2xl font-semibold mb-3">💼 Careers</h3>
        <p class="text-gray-400 mb-6">
          We’re building the future of Roblox community tools. Explore roles and grow with us.
        </p>
        <button onclick="openRolesModal()" class="btn-primary px-6 py-3">See Roles</button>
      </div>

      <div class="bg-[#111] p-10 rounded-2xl text-center border border-[#1c1c1c]">
        <h3 class="text-2xl font-semibold mb-3">💬 Support</h3>
        <p class="text-gray-400 mb-6">
          Have questions or need help? Our support team is always here for you.
        </p>
        <a href="/support" class="btn-primary px-6 py-3">Get Help</a>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- Roles Modal -->
  <div id="rolesModal" class="fixed inset-0 bg-black/80 hidden items-start justify-center overflow-y-auto pt-24 sm:pt-32 z-50">
    <div class="bg-[#111] p-8 w-full max-w-2xl relative rounded-2xl border border-[#1c1c1c]">
      <button class="absolute top-4 right-4 text-gray-400 hover:text-white text-2xl" onclick="closeRolesModal()">✕</button>
      <h2 class="text-2xl font-bold mb-6 text-center">Open Roles</h2>

      <div class="grid gap-6">
        <div class="bg-[#0d0d0d] p-6 rounded-xl border border-[#1c1c1c]">
          <h3 class="text-xl font-semibold mb-2">Developer</h3>
          <p class="text-gray-400 mb-3">Work on Keylo’s systems, APIs, and interfaces. Portfolio links encouraged.</p>
          <button class="btn-primary px-4 py-2 rounded-lg" onclick="openApplyForm('Developer')">Apply</button>
        </div>

        <div class="bg-[#0d0d0d] p-6 rounded-xl border border-[#1c1c1c]">
          <h3 class="text-xl font-semibold mb-2">Support</h3>
          <p class="text-gray-400 mb-3">Help users and handle tickets, ensuring a great Keylo experience.</p>
          <button class="btn-primary px-4 py-2 rounded-lg" onclick="openApplyForm('Support')">Apply</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Apply Modal -->
  <div id="applyModal" class="fixed inset-0 bg-black/80 hidden items-start justify-center overflow-y-auto pt-24 sm:pt-32 z-50">
    <div class="bg-[#111] p-8 w-full max-w-lg relative rounded-2xl border border-[#1c1c1c]">
      <button class="absolute top-4 right-4 text-gray-400 hover:text-white text-2xl" onclick="closeApplyForm()">✕</button>
      <h2 class="text-2xl font-bold mb-4 text-center" id="applyRoleTitle">Apply</h2>

      <form id="applyForm" class="space-y-4">
        <input type="text" name="roblox" placeholder="Roblox Username" required class="w-full p-3 rounded-lg bg-black/30 border border-gray-700 text-white">
        <input type="text" name="discord" placeholder="Discord Username" required class="w-full p-3 rounded-lg bg-black/30 border border-gray-700 text-white">
        <input type="email" name="email" placeholder="Contact Email" required class="w-full p-3 rounded-lg bg-black/30 border border-gray-700 text-white">
        <input type="number" name="age" placeholder="Age" required class="w-full p-3 rounded-lg bg-black/30 border border-gray-700 text-white">
        <textarea name="why" placeholder="Why do you want to work here?" required class="w-full p-3 rounded-lg bg-black/30 border border-gray-700 text-white"></textarea>
        <textarea name="experience" placeholder="Previous experience / portfolio link" class="w-full p-3 rounded-lg bg-black/30 border border-gray-700 text-white"></textarea>
        <button type="submit" class="btn-primary w-full py-3 rounded-lg font-medium">Submit Application</button>
      </form>
    </div>
  </div>

  <!-- Footer -->
  <footer class="relative bg-[#0d0d0d] py-12 text-gray-500 text-sm animate-fadeUp delay-3 dotted-bg">
    <div class="max-w-7xl mx-auto px-6 flex flex-col md:flex-row justify-between items-center gap-6">
      <p>© <%= new Date().getFullYear() %> Keylo. All rights reserved.</p>
      <nav class="flex gap-6 text-sm">
        <a href="#" class="hover:text-white">Privacy</a>
        <a href="#" class="hover:text-white">Terms</a>
        <a href="/support" class="hover:text-white">Support</a>
      </nav>
    </div>
  </footer>

  <script>
    function openRolesModal(){ document.getElementById('rolesModal').classList.remove('hidden'); }
    function closeRolesModal(){ document.getElementById('rolesModal').classList.add('hidden'); }
    function openApplyForm(role){
      document.getElementById('applyRoleTitle').innerText = `Apply: ${role}`;
      document.getElementById('applyModal').classList.remove('hidden');
      document.getElementById('applyForm').dataset.role = role;
    }
    function closeApplyForm(){
      document.getElementById('applyModal').classList.add('hidden');
      document.getElementById('applyForm').reset();
    }

    document.getElementById('applyForm').addEventListener('submit', async function(e){
      e.preventDefault();
      const form = e.target;
      const role = form.dataset.role;
      const csrfToken = '<%= csrfToken %>';
      const payload = {
        role,
        roblox: form.roblox.value,
        discord: form.discord.value,
        email: form.email.value,
        age: form.age.value,
        why: form.why.value,
        experience: form.experience.value
      };

      try {
        const res = await fetch('/apply', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'CSRF-Token': csrfToken },
          body: JSON.stringify(payload)
        });
        const data = await res.json();
        if (data.success) {
          alert('✅ Application submitted successfully!');
          closeApplyForm();
        } else {
          alert('❌ Failed to submit application: ' + (data.error || 'Unknown error'));
        }
      } catch (err) {
        console.error(err);
        alert('❌ Error submitting application.');
      }
    });
  </script>
</body>
</html>
