<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Keylo — Next Chapter</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&family=Outfit:wght@600;800&display=swap" rel="stylesheet">

  <style>
    body { font-family: 'Inter', sans-serif; }
    h1,h2,h3,h4 { font-family: 'Outfit', sans-serif; }

    .glass {
      background: rgba(255, 255, 255, 0.08);
      backdrop-filter: blur(20px) saturate(200%);
      -webkit-backdrop-filter: blur(20px) saturate(200%);
      border-radius: 22px;
      border: 1px solid rgba(255, 255, 255, 0.15);
      box-shadow: 0 8px 30px rgba(0, 0, 0, 0.1);
    }

    .btn-primary {
      background: linear-gradient(to right, #7e22ce, #9333ea);
      color: white;
      transition: all 0.3s ease;
    }
    .btn-primary:hover {
      background: linear-gradient(to right, #6b21a8, #7e22ce);
    }

    .btn-secondary {
      background: rgba(255, 255, 255, 0.1);
      color: #374151;
      transition: all 0.3s ease;
    }
    .btn-secondary:hover {
      background: rgba(255, 255, 255, 0.2);
    }

    .glow-text { text-shadow: 0 0 6px rgba(200, 150, 255, 0.5); }
  </style>
</head>
<body class="bg-gradient-to-br from-gray-50 via-purple-50 to-purple-100 text-slate-900 flex flex-col min-h-screen">

<!-- Header -->
<header class="fixed w-full glass z-50">
  <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between relative">
    <div class="flex items-center gap-3">
      <div class="glass w-11 h-11 rounded-full overflow-hidden">
        <img src="<%= typeof userProfileURL !== 'undefined' ? userProfileURL : '/images/default-avatar.png' %>" 
             alt="Profile" 
             class="w-full h-full object-cover">
      </div>
      <h2 class="text-base font-semibold text-slate-800">
        Welcome, <%= typeof user !== 'undefined' ? user : 'Guest' %>
      </h2>
    </div>
    <a href="/launch" class="absolute left-1/2 transform -translate-x-1/2 text-2xl font-extrabold glow-text text-purple-800">
      Keylo
    </a>
    <a href="/signout" class="btn-secondary px-4 py-2 rounded-lg text-sm font-medium">Sign Out</a>
  </div>
</header>

<!-- Hero Section -->
<main class="flex-grow pt-32 pb-20 px-6">
  <section class="text-center max-w-3xl mx-auto">
    <h1 class="text-5xl sm:text-6xl font-extrabold mb-6 text-purple-800 glow-text">Something New is on the Horizon</h1>
    <p class="text-lg sm:text-xl text-slate-700 leading-relaxed mb-6">
      The next evolution of <span class="font-semibold">Keylo</span> is almost here. Manage your community with ease, automate routine tasks, and gain valuable insights — all in one place.
    </p>
    <p class="text-slate-600 font-medium">Expected launch: <span class="font-semibold text-purple-700">N.A</span></p>
  </section>

  <section class="max-w-6xl mx-auto mt-16 grid gap-8 md:grid-cols-3">
    <div class="glass p-8 rounded-2xl text-center">
      <h3 class="text-2xl font-semibold mb-3 text-purple-800">🚀 Beta Access</h3>
      <p class="text-slate-700 mb-4 leading-relaxed">
        Be the first to explore new Keylo features. Join the beta program and help us refine the experience with your feedback.
      </p>
      <a href="#" class="btn-primary px-6 py-3 rounded-lg font-medium shadow-md inline-block">Apply Now</a>
    </div>

    <div class="glass p-8 rounded-2xl text-center">
      <h3 class="text-2xl font-semibold mb-3 text-purple-800">💼 Careers</h3>
      <p class="text-slate-700 mb-4 leading-relaxed">
        We're building the future of community management. Explore open positions and become part of the Keylo journey.
      </p>
      <button onclick="openRolesModal()" class="btn-primary px-6 py-3 rounded-lg font-medium shadow-md inline-block">See Roles</button>
    </div>

    <div class="glass p-8 rounded-2xl text-center">
      <h3 class="text-2xl font-semibold mb-3 text-purple-800">💜 Support</h3>
      <p class="text-slate-700 mb-4 leading-relaxed">
        Have questions or need help? Our support team is ready to assist you with any issues, big or small.
      </p>
      <a href="support" class="btn-primary px-6 py-3 rounded-lg font-medium shadow-md inline-block">Get Help</a>
    </div>
  </section>
</main>

<!-- Roles Modal -->
<div id="rolesModal" class="fixed inset-0 bg-black bg-opacity-50 flex items-start justify-center overflow-y-auto pt-24 sm:pt-32 hidden z-50">
  <div class="bg-white rounded-2xl p-8 w-full max-w-2xl relative">
    <button class="absolute top-4 right-4 text-gray-500 hover:text-gray-900" onclick="closeRolesModal()">✕</button>
    <h2 class="text-2xl font-bold text-purple-800 mb-4 text-center glow-text">Open Roles</h2>

    <div class="grid gap-6">
      <div class="glass p-6 rounded-2xl">
        <h3 class="text-xl font-semibold mb-2 text-purple-800">Developer</h3>
        <p class="text-slate-700 mb-3">Work on Keylo features, scripts, and integrations. Provide a portfolio link if available.</p>
        <button class="btn-primary px-4 py-2 rounded-lg" onclick="openApplyForm('Developer')">Apply</button>
      </div>
      <div class="glass p-6 rounded-2xl">
        <h3 class="text-xl font-semibold mb-2 text-purple-800">Support</h3>
        <p class="text-slate-700 mb-3">Assist users and handle support tickets to maintain a smooth community experience.</p>
        <button class="btn-primary px-4 py-2 rounded-lg" onclick="openApplyForm('Support')">Apply</button>
      </div>
    </div>
  </div>
</div>

<!-- Application Form Modal -->
<div id="applyModal" class="fixed inset-0 bg-black bg-opacity-50 flex items-start justify-center overflow-y-auto pt-24 sm:pt-32 hidden z-50">
  <div class="bg-white rounded-2xl p-8 w-full max-w-lg relative">
    <button class="absolute top-4 right-4 text-gray-500 hover:text-gray-900" onclick="closeApplyForm()">✕</button>
    <h2 class="text-2xl font-bold text-purple-800 mb-4" id="applyRoleTitle">Apply</h2>

    <form id="applyForm" class="space-y-4">
      <input type="text" name="roblox" placeholder="Roblox Username" required class="w-full p-3 border rounded-lg">
      <input type="text" name="discord" placeholder="Discord Username" required class="w-full p-3 border rounded-lg">
      <input type="email" name="email" placeholder="Contact Email" required class="w-full p-3 border rounded-lg">
      <input type="number" name="age" placeholder="Age" required class="w-full p-3 border rounded-lg">
      <textarea name="why" placeholder="Why do you want to work here?" required class="w-full p-3 border rounded-lg"></textarea>
      <textarea name="experience" placeholder="Previous experience / portfolio link" class="w-full p-3 border rounded-lg"></textarea>
      <button type="submit" class="btn-primary w-full py-3 rounded-lg font-medium">Submit Application</button>
    </form>
  </div>
</div>

<!-- Footer -->
<footer class="bg-gradient-to-br from-purple-900 via-purple-800 to-purple-700 text-white py-8 mt-16">
  <div class="max-w-7xl mx-auto px-6 flex flex-col md:flex-row justify-between items-center gap-6">
    <p class="text-sm">© <%= new Date().getFullYear() %> Keylo. All rights reserved.</p>
    <nav class="flex gap-6 text-sm">
      <a href="#" class="hover:text-purple-200">Privacy</a>
      <a href="#" class="hover:text-purple-200">Terms</a>
      <a href="support" class="hover:text-purple-200">Support</a>
    </nav>
  </div>
</footer>

<script>
  // Roles Modal
  function openRolesModal() { 
    document.getElementById('rolesModal').classList.remove('hidden'); 
  }
  function closeRolesModal() { 
    document.getElementById('rolesModal').classList.add('hidden'); 
  }

  // Apply Form Modal
  function openApplyForm(role) {
    document.getElementById('applyRoleTitle').innerText = `Apply: ${role}`;
    document.getElementById('applyModal').classList.remove('hidden');
    document.getElementById('applyForm').dataset.role = role;
  }
  function closeApplyForm() {
    document.getElementById('applyModal').classList.add('hidden');
    document.getElementById('applyForm').reset();
  }

  // Handle form submission via AJAX
  document.getElementById('applyForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    const role = e.target.dataset.role;
    const roblox = e.target.roblox.value;
    const discord = e.target.discord.value;
    const email = e.target.email.value;
    const age = e.target.age.value;
    const why = e.target.why.value;
    const experience = e.target.experience.value;

    const csrfToken = '<%= csrfToken %>';

    try {
      const res = await fetch('/apply', {
        method: 'POST',
        headers: { 
          'Content-Type': 'application/json',
          'CSRF-Token': csrfToken
        },
        body: JSON.stringify({ role, roblox, discord, email, age, why, experience })
      });

      const data = await res.json();

      if (data.success) {
        alert('✅ Application submitted successfully!');
        closeApplyForm();
      } else {
        alert('❌ Failed to submit application: ' + (data.error || 'Unknown error'));
      }
    } catch (err) {
      console.error(err);
      alert('❌ Error submitting application. Check console.');
    }
  });
</script>


</body>
</html>
