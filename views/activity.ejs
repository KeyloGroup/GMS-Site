<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Activity — <%= workspace.name %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&family=Outfit:wght@600;800&display=swap" rel="stylesheet">
  <script src="https://kit.fontawesome.com/a076d05399.js" crossorigin="anonymous"></script>

  <style>
    body {
      background-color: #000;
      color: #fff;
      font-family: 'Inter', sans-serif;
    }
    h1, h2, h3, h4 {
      font-family: 'Outfit', sans-serif;
    }

    .gradient-bg {
      background: radial-gradient(circle at 70% 50%, rgba(0, 51, 153, 0.5), rgba(0, 0, 0, 0.9) 70%),
                  linear-gradient(135deg, rgba(0, 0, 64, 0.8), rgba(0, 0, 0, 0.95));
    }

    .glass {
      background: rgba(255, 255, 255, 0.05);
      backdrop-filter: blur(14px);
      -webkit-backdrop-filter: blur(14px);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 22px;
    }

    .sidebar-link img {
      filter: brightness(0) invert(1);
    }
    
    .sidebar-link {
      display: flex;
      align-items: center;
      gap: .75rem;
      padding: .75rem .9rem;
      border-radius: .75rem;
      color: #9ca3af;
      font-weight: 500;
      transition: all 0.3s ease;
    }
    .sidebar-link:hover {
      background-color: rgba(37, 99, 235, 0.15);
      color: #60a5fa;
      transform: translateX(4px);
    }
    .sidebar-active {
      background-color: rgba(37, 99, 235, 0.25);
      color: #3b82f6;
      font-weight: 600;
    }

    .glow-text {
      text-shadow: 0 0 8px rgba(60, 100, 255, 0.5);
    }
  </style>
</head>

<body class="gradient-bg text-white flex min-h-screen">

  <!-- Sidebar -->
  <aside class="w-20 md:w-64 p-4 glass flex flex-col shadow-xl">
    <div class="flex flex-col items-center mb-10">
      <img src="<%= workspace.image %>" alt="Workspace Icon" class="w-14 h-14 rounded-full mb-2 shadow-md">
      <p class="text-gray-300 text-sm font-semibold text-center"><%= workspace.name %></p>
    </div>

    <div class="border-t border-gray-700 mb-4"></div>

    <nav class="flex flex-col gap-2 flex-1">
      <a href="/workspace/<%= workspace.id %>/" class="sidebar-link">
        <img src="/icons/icons8-home-48.png" class="w-5 h-5"> <span>Home</span>
      </a>
      <a href="#" class="sidebar-link">
        <img src="/icons/icons8-checked-box-50.png" class="w-5 h-5"> <span>Tasks</span>
      </a>
      <a href="#" class="sidebar-link">
        <img src="/icons/icons8-open-book-50.png" class="w-5 h-5"> <span>Logbook</span>
      </a>
      <a href="/workspace/<%= workspace.id %>/sessions" class="sidebar-link">
        <img src="/icons/icons8-calendar-50.png" class="w-5 h-5"> <span>Sessions</span>
      </a>
      <a href="#" class="sidebar-link">
        <img src="/icons/icons8-avatar-24.png" class="w-5 h-5"> <span>Staff</span>
      </a>
      <a href="/workspace/<%= workspace.id %>/activity" class="sidebar-link sidebar-active">
        <img src="/icons/icons8-clock-24.png" class="w-5 h-5"> <span>Activity</span>
      </a>
      <a href="#" class="sidebar-link">
        <img src="/icons/icons8-airplane-take-off-50.png" class="w-5 h-5"> <span>Leave</span>
      </a>
      <a href="#" class="sidebar-link">
        <img src="/icons/icons8-folder-50.png" class="w-5 h-5"> <span>Documents</span>
      </a>
    </nav>

    <div class="border-t border-gray-700 mt-4"></div>

    <a href="/workspace/<%= workspace.id %>/settings" class="sidebar-link mt-4">
      <img src="/icons/icons8-settings-50.png" class="w-5 h-5">
      <span>Settings</span>
    </a>

    <div class="mt-6 flex items-center gap-3 p-2 glass rounded-xl">
      <img src="<%= userProfileURL %>" alt="Profile" class="w-10 h-10 rounded-full shadow">
      <div class="hidden md:block">
        <p class="text-sm font-semibold text-white"><%= user %></p>
        <p class="text-xs text-gray-400">Online</p>
      </div>
    </div>
  </aside>

  <!-- Main -->
  <main class="flex-1 p-8 overflow-y-auto">
    <header class="flex justify-between items-center mb-12">
      <div>
        <h1 class="text-3xl font-extrabold glow-text">Activity Overview</h1>
        <p class="text-gray-400 text-sm">View your recent activity and stats</p>
      </div>
      <div class="flex items-center gap-4">
        <input class="glass px-4 py-2 rounded-full placeholder-gray-400 text-white w-64 focus:outline-none focus:ring-2 focus:ring-blue-400" placeholder="Search..." />
        <button class="glass p-2 rounded-full hover:bg-blue-600/20 transition">
          <i class="fas fa-bell text-blue-400"></i>
        </button>
      </div>

    </header>

    <!-- Stats -->
    <section class="grid md:grid-cols-4 gap-6 mb-10">
      <div class="glass p-5 text-center hover:-translate-y-1 transition-all">
        <p class="text-sm text-gray-400 mb-1">Today's Time</p>
        <p class="text-3xl font-bold text-blue-400"><%= todaysTime || 0 %>m</p>
      </div>
      <div class="glass p-5 text-center hover:-translate-y-1 transition-all">
        <p class="text-sm text-gray-400 mb-1">Daily Average</p>
        <p class="text-3xl font-bold text-blue-400"><%= dailyAverage || 0 %>m</p>
      </div>
      <div class="glass p-5 text-center hover:-translate-y-1 transition-all">
        <p class="text-sm text-gray-400 mb-1">Total Time</p>
        <p class="text-3xl font-bold text-blue-400"><%= totalTime || 0 %>m</p>
      </div>
      <div class="glass p-5 text-center hover:-translate-y-1 transition-all">
        <p class="text-sm text-gray-400 mb-1">Today's Chats</p>
        <p class="text-3xl font-bold text-blue-400"><%= todaysChats || 0 %></p>
      </div>
    </section>

    <!-- Recent Activity -->
    <section>
      <h2 class="text-xl font-semibold mb-4 glow-text">Recent Activity</h2>
      <% if (activity && activity.length > 0) { %>
        <div class="glass p-5">
          <ul class="divide-y divide-gray-700">
            <% activity.forEach(a => { %>
              <li class="py-4 flex justify-between items-center">
                <div class="flex items-center gap-3">
                  <div class="p-2 bg-blue-600/20 rounded-full text-blue-400">
                    <i class="fas fa-clock"></i>
                  </div>
                  <div>
                    <p class="font-medium text-white"><%= a.user %></p>
                    <p class="text-xs text-gray-400"><%= a.description %></p>
                    <p class="text-xs text-gray-500"><%= a.time %></p>
                  </div>
                </div>
                <span class="text-xs px-2 py-1 font-semibold rounded-full
                  <% if (a.type === 'session') { %> bg-green-700/30 text-green-400 <% } 
                  else if (a.type === 'adjustment') { %> bg-yellow-700/30 text-yellow-400 <% } 
                  else { %> bg-blue-700/30 text-blue-400 <% } %>">
                  <%= a.type.charAt(0).toUpperCase() + a.type.slice(1) %>
                </span>
              </li>
            <% }) %>
          </ul>
        </div>
      <% } else { %>
        <div class="glass flex flex-col items-center justify-center py-20">
          <div class="mb-4 text-blue-400">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 22q-1.875 0-3.512-.712t-2.85-1.925t-1.925-2.85T3 13t.713-3.512t1.924-2.85t2.85-1.925T12 4t3.513.713t2.85 1.925t1.925 2.85T21 13t-.712 3.513t-1.925 2.85t-2.85 1.925T12 22m2.8-4.8l1.4-1.4l-3.2-3.2V8h-2v5.4zM5.6 2.35L7 3.75L2.75 8l-1.4-1.4zm12.8 0l4.25 4.25l-1.4 1.4L17 3.75zM12 20q2.925 0 4.963-2.037T19 13t-2.037-4.962T12 6T7.038 8.038T5 13t2.038 4.963T12 20"/>
            </svg>
          </div>
          <p class="text-gray-400 text-lg font-medium">No recent activity</p>
        </div>

      <% } %>
    </section>
  </main>
</body>
</html>
