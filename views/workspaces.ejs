<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Keylo — Workspaces</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&family=Outfit:wght@600;800&display=swap" rel="stylesheet">

  <style>
    body {
      font-family: 'Inter', sans-serif;
      background-color: #0d0d0d;
      color: #fff;
      min-height: 100vh;
      overflow-x: hidden;
    }

    h1, h2, h3, h4 { font-family: 'Outfit', sans-serif; }

    /* dotted background like index.ejs */
    .dotted-bg {
      background-image: radial-gradient(#222 1px, transparent 1px);
      background-size: 24px 24px;
      position: relative;
      z-index: 0;
    }
    .dotted-bg::before {
      content: "";
      position: absolute;
      inset: 0;
      background: radial-gradient(#1a1a1a 1px, transparent 1px);
      background-size: 24px 24px;
      opacity: 0.5;
      pointer-events: none;
      z-index: 0;
    }

    .glass {
      background: rgba(255, 255, 255, 0.05);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 22px;
      transition: all 0.3s ease;
    }

    .glass:hover {
      border-color: rgba(255, 255, 255, 0.25);
      transform: translateY(-2px);
    }

    .btn-primary {
      background-color: #fff;
      color: #000;
      font-weight: 600;
      border-radius: 10px;
      transition: all 0.3s ease;
    }
    .btn-primary:hover { background-color: #eaeaea; }

    .btn-secondary {
      background-color: transparent;
      color: #fff;
      border: 1px solid #333;
      font-weight: 600;
      border-radius: 10px;
      transition: all 0.3s ease;
    }
    .btn-secondary:hover {
      border-color: #555;
      background-color: #111;
    }

    .divider { border-top: 1px solid #1a1a1a; }

    .glow-text {
      text-shadow: 0 0 6px rgba(60, 100, 255, 0.4);
    }

    input {
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(255, 255, 255, 0.2);
      border-radius: 12px;
      color: #fff;
      padding: 0.75rem;
      width: 100%;
      outline: none;
      transition: all 0.2s ease;
    }
    input:focus {
      border-color: #2563eb;
      box-shadow: 0 0 0 2px rgba(37, 99, 235, 0.3);
    }
  </style>
</head>

<body class="flex flex-col dotted-bg">

<!-- Header -->
<header class="fixed w-full bg-[#0d0d0d]/90 backdrop-blur-lg border-b border-[#1a1a1a] z-50">
  <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between relative">
    <div class="flex items-center gap-3">
      <div class="w-11 h-11 rounded-full overflow-hidden border border-white/10">
        <img src="<%= typeof userProfileURL !== 'undefined' ? userProfileURL : '/images/default-avatar.png' %>" alt="Profile" class="w-full h-full object-cover">
      </div>
      <h2 class="text-base font-semibold text-gray-200">
        Welcome, <%= typeof user !== 'undefined' ? user : 'Guest' %>
      </h2>
    </div>
    <a href="/launch" class="absolute left-1/2 transform -translate-x-1/2 text-2xl font-extrabold text-white">Keylo</a>
    <a href="/logout" class="btn-secondary px-4 py-2 rounded-lg text-sm font-medium">Sign Out</a>
  </div>
</header>

<!-- Main -->
<main class="flex-grow pt-32 pb-20 px-6 max-w-7xl mx-auto relative z-10">
  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-12 gap-6">
    <div>
      <h1 class="text-5xl font-extrabold mb-2">Your Workspaces</h1>
      <p class="text-gray-400">Manage and access all your workspaces in one place.</p>
    </div>
    <button onclick="openNewWorkspaceModal()" class="btn-primary px-6 py-3 rounded-xl font-medium shadow-lg">
      + New Workspace
    </button>
  </div>

  <!-- Divider -->
  <div class="divider mb-12"></div>

  <!-- Workspaces Grid -->
  <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3 w-full">
    <% if (workspaces && workspaces.length > 0) { %>
      <% workspaces.forEach(ws => { %>
        <a href="/workspace/<%= ws.id %>" class="glass overflow-hidden hover:shadow-xl group relative">
          <div class="h-48 w-full flex items-center justify-center overflow-hidden">
            <img src="<%= ws.image || '/images/default-workspace.png' %>" alt="<%= ws.name %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300">
          </div>
          <div class="p-5 border-t border-white/10 relative z-10">
            <h3 class="text-lg font-bold text-white group-hover:text-blue-400 transition-colors">
              <%= ws.name %>
            </h3>
            <% if (ws.groupId) { %>
              <p class="text-sm text-gray-400 mt-1">Group ID: <%= ws.groupId %></p>
            <% } %>
          </div>
        </a>
      <% }) %>
    <% } else { %>
      <div class="glass flex flex-col items-center justify-center text-center py-16 w-full">
        <h3 class="text-xl font-semibold text-white mb-2">No workspaces yet</h3>
        <p class="text-gray-400 mb-6">Create a workspace to start collaborating and organizing your projects.</p>
        <button onclick="openNewWorkspaceModal()" class="btn-primary px-6 py-3 rounded-xl font-medium shadow">
          + Create Your First Workspace
        </button>
      </div>
    <% } %>
  </div>
</main>

<!-- Divider -->
<div class="divider"></div>

<!-- New Workspace Modal -->
<div id="workspaceModal" class="fixed inset-0 bg-black bg-opacity-70 flex items-start justify-center overflow-y-auto pt-24 hidden z-50">
  <div class="glass p-8 w-full max-w-lg relative">
    <button class="absolute top-4 right-4 text-gray-400 hover:text-white" onclick="closeNewWorkspaceModal()">✕</button>
    <h2 class="text-3xl font-bold text-blue-400 mb-6 text-center">Create New Workspace</h2>

    <form id="workspaceForm" class="space-y-4">
      <input type="text" name="name" placeholder="Workspace Name" required>
      <input type="url" name="image" placeholder="Image URL" required>
      <input type="number" name="groupId" placeholder="Roblox Group ID (optional)">
      <input type="number" name="minRank" placeholder="Minimum Rank ID (optional)">
      <button type="submit" class="btn-primary w-full py-3 rounded-lg font-medium">Create Workspace</button>
    </form>
  </div>
</div>

<script>
  function openNewWorkspaceModal() {
    document.getElementById('workspaceModal').classList.remove('hidden');
  }
  function closeNewWorkspaceModal() {
    document.getElementById('workspaceModal').classList.add('hidden');
    document.getElementById('workspaceForm').reset();
  }

  document.getElementById('workspaceForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    const name = e.target.name.value;
    const image = e.target.image.value;
    const groupId = e.target.groupId.value || null;
    const minRank = e.target.minRank.value || null;
    const csrfToken = '<%= csrfToken %>';

    try {
      const res = await fetch('/workspace/create', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'CSRF-Token': csrfToken },
        body: JSON.stringify({ name, image, groupId, minRank })
      });
      const data = await res.json();
      if (data.success) {
        alert('✅ Workspace created!');
        location.reload();
      } else {
        alert('❌ Failed: ' + (data.error || 'Unknown error'));
      }
    } catch (err) {
      console.error(err);
      alert('❌ Error creating workspace');
    }
  });
</script>

</body>
</html>
