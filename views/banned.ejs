<!DOCTYPE html>
<html lang="en" class="scroll-smooth antialiased dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Account Banned - Keylo</title>
  
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="icon" href="/assets/keylo-logo.png">
  
  <style>
    body {
      background-color: #000000;
      color: #ededed;
      font-family: 'Inter', sans-serif;
      overflow-x: hidden;
    }
    .bg-noise {
      position: fixed;
      top: 0; left: 0; width: 100vw; height: 100vh;
      pointer-events: none;
      z-index: 50;
      opacity: 0.04;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
    }
    .card-modern {
      background: #0a0a0a;
      border: 1px solid #1f1f1f;
      border-radius: 1.5rem;
      padding: 2rem;
      text-align: center;
      max-width: 400px;
      margin: auto;
      box-shadow: 0 0 30px rgba(255,255,255,0.02);
    }
    .text-glow {
      color: #ef4444;
      text-shadow: 0 0 10px #ef4444;
    }
    .btn-main {
      background: #ef4444;
      color: #fff;
      font-weight: 600;
      padding: 0.75rem 2rem;
      border-radius: 0.75rem;
      display: inline-block;
      transition: background 0.2s, transform 0.15s;
    }
    .btn-main:hover {
      background: #b91c1c;
      transform: scale(1.05);
    }
  </style>
</head>
<body class="relative selection:bg-white selection:text-black">

  <div class="bg-noise"></div>

  <section class="min-h-screen flex flex-col items-center justify-center px-6">
    <div class="card-modern">
      <div class="text-6xl mb-4 text-glow">⛔</div>
      <h1 class="text-3xl font-bold mb-4 text-glow">Account Banned</h1>
      <p class="text-[#888] mb-4">
        Sorry <span class="font-semibold text-white"><%= username %></span>, your account has been banned.
      </p>
      <p class="text-[#aaa] mb-6">
        Reason: <span class="font-semibold text-red-400"><%= reason %></span>
      </p>
      <p class="text-[#888] mb-6">
        Redirecting in <span id="countdown" class="font-bold text-red-400">10</span> seconds…
      </p>
      <a href="<%= redirectUrl %>" class="btn-main">Return to Home</a>
    </div>
  </section>

  <script>
    const countdownEl = document.getElementById("countdown");
    const redirectUrl = "<%= redirectUrl %>";
    let seconds = 10;
    const timer = setInterval(() => {
      seconds--;
      countdownEl.textContent = seconds;
      if (seconds <= 0) {
        clearInterval(timer);
        window.location.href = redirectUrl;
      }
    }, 1000);
  </script>
</body>
</html>
