<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Banned - Keylo</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">
  <link rel="icon" href="/assets/keylo-logo.png">
  <style>
    body {
      background-color: #0d0d0d;
      color: #fff;
      font-family: 'Inter', sans-serif;
      min-height: 100vh;
      min-width: 100vw;
      margin: 0;
      padding: 0;
      overflow-x: hidden;
    }
    .dotted-bg {
      position: fixed;
      inset: 0;
      background-image: radial-gradient(#222 1px, transparent 1px);
      background-size: 24px 24px;
      z-index: 0;
    }
    .dotted-bg::before {
      content: "";
      position: absolute;
      inset: 0;
      background: radial-gradient(#1a1a1a 1px, transparent 1px);
      background-size: 24px 24px;
      opacity: 0.5;
      pointer-events: none;
    }
    .glass {
      background: rgba(24, 24, 24, 0.7);
      backdrop-filter: blur(14px);
      border-radius: 22px;
      border: 1px solid #222;
      box-shadow: 0 8px 30px rgba(0,0,0,0.28);
      z-index: 1;
    }
    .glow-text {
      text-shadow: 0 0 7px rgba(255, 0, 0, 0.44);
    }
    .underline-animated {
      display: inline-block;
      position: relative;
    }
    .underline-animated::after {
      content: '';
      position: absolute;
      left: 0;
      bottom: -3px;
      width: 100%;
      height: 3px;
      background: linear-gradient(90deg, #f87171 0%, #ef4444 100%);
      border-radius: 2px;
      animation: underline-grow 1.1s cubic-bezier(0.4, 0, 0.2, 1);
    }
    @keyframes underline-grow {
      from { width: 0; }
      to { width: 100%; }
    }
    @keyframes shake {
      0%, 100% { transform: translateX(0);}
      20% { transform: translateX(-5px);}
      40% { transform: translateX(5px);}
      60% { transform: translateX(-5px);}
      80% { transform: translateX(5px);}
    }
    .shake {
      animation: shake 0.7s;
    }
    .fadein {
      animation: fadeIn 0.8s cubic-bezier(0.4, 0, 0.2, 1);
    }
    @keyframes fadeIn {
      from { opacity: 0;}
      to { opacity: 1;}
    }
    .btn-main {
      background: #ef4444;
      color: #fff;
      transition: background 0.18s, transform .14s;
      border-radius: 0.75rem;
      padding: 0.75rem 2rem;
      font-weight: 600;
      display: inline-block;
      margin-top: 1.5rem;
      box-shadow: 0 2px 12px 0 #15151560;
      outline: none;
      border: none;
      text-decoration: none;
      letter-spacing: .01em;
    }
    .btn-main:hover, .btn-main:focus {
      background: #b91c1c;
      transform: translateY(-2px) scale(1.03);
    }
    @media (max-width: 600px) {
      .glass {
        padding: 1.7rem 0.7rem;
      }
      .btn-main {
        padding: 0.7rem 1rem;
      }
    }
  </style>
</head>
<body>
  <div class="dotted-bg"></div>
  <div class="flex items-center justify-center min-h-screen relative fadein" style="z-index:1;">
    <div class="glass p-10 max-w-lg w-full text-center mx-2 shadow-2xl transition-all duration-200">
      <div class="text-6xl mb-6 text-red-600 shake select-none" id="denied-emoji">â›”</div>
      <h1 class="text-3xl md:text-4xl font-extrabold glow-text mb-4">
        <span class="underline-animated">Account Banned</span>
      </h1>
      <p class="text-gray-300 mb-6">
        Sorry <span class="font-semibold"><%= username %></span>, your account has been banned.
      </p>
      <p class="text-gray-400 mb-4">
        Reason: <span class="font-semibold text-red-400"><%= reason %></span>
      </p>
      <p class="text-gray-400 mb-4">
        Redirecting in <span id="countdown" class="font-bold text-red-400">10</span> secondsâ€¦
      </p>
      <a href="<%= redirectUrl %>" class="btn-main">Return to Home</a>
    </div>
  </div>
  <script>
    const countdownEl = document.getElementById("countdown");
    const redirectUrl = "<%= redirectUrl %>";
    let seconds = 10;
    let shakeInterval;
    function shake() {
      const emoji = document.getElementById("denied-emoji");
      emoji.classList.remove("shake");
      void emoji.offsetWidth;
      emoji.classList.add("shake");
    }
    function tick() {
      seconds--;
      if (seconds > 0) {
        countdownEl.textContent = seconds;
        shake();
      } else {
        countdownEl.textContent = "0";
        window.location.replace(redirectUrl);
        clearInterval(shakeInterval);
        clearInterval(timer);
      }
    }
    shakeInterval = setInterval(shake, 3000);
    const timer = setInterval(tick, 1000);
    window.addEventListener('keydown', e => {
      if (e.key === "Enter") window.location.href = redirectUrl;
    });
  </script>
</body>
</html>
