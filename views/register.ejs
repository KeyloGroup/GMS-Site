<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Keylo — Register</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&family=Outfit:wght@600;800&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Inter', sans-serif; }
    h1, h2, h3, h4 { font-family: 'Outfit', sans-serif; }

    .glass {
      background: rgba(255, 255, 255, 0.08);
      backdrop-filter: blur(20px) saturate(200%);
      -webkit-backdrop-filter: blur(20px) saturate(200%);
      border-radius: 22px;
      border: 1px solid rgba(255, 255, 255, 0.15);
      box-shadow: 0 8px 30px rgba(0, 0, 0, 0.1);
    }

    .btn-primary {
      background: linear-gradient(to right, #7e22ce, #9333ea);
      color: white;
      transition: all 0.3s ease;
    }
    .btn-primary:hover {
      background: linear-gradient(to right, #6b21a8, #7e22ce);
    }

    .btn-secondary {
      background: rgba(255, 255, 255, 0.1);
      color: #374151;
      transition: all 0.3s ease;
    }
    .btn-secondary:hover {
      background: rgba(255, 255, 255, 0.2);
    }

    .glow-text {
      text-shadow: 0 0 6px rgba(200, 150, 255, 0.6);
    }
  </style>
</head>
<body class="bg-gradient-to-br from-gray-50 via-purple-50 to-purple-100 text-slate-900 min-h-screen flex items-center justify-center px-4">

<div class="glass max-w-md w-full p-8">
  <h2 class="text-4xl font-extrabold text-center mb-8 text-purple-800 glow-text">Register</h2>

  <!-- Step 1: Roblox User ID -->
  <div id="step1">
    <label for="robloxIdInput" class="block text-sm font-medium text-slate-700 mb-2">Roblox User ID</label>
    <input id="robloxIdInput" type="text" class="w-full p-3 rounded-lg bg-white/60 border border-purple-200 focus:border-purple-500 focus:ring focus:ring-purple-200 outline-none mb-4" placeholder="Enter your Roblox User ID">
    <button onclick="lookupRobloxUser()" class="btn-primary w-full py-3 rounded-lg font-semibold">Continue</button>
  </div>

  <!-- Step 2: Confirm Profile -->
  <div id="step2" class="hidden text-center">
    <img id="robloxAvatar" class="mx-auto rounded-full w-24 h-24 mb-4 shadow-md" src="" alt="Avatar">
    <p id="robloxName" class="text-xl font-semibold text-purple-800"></p>
    <p id="robloxIdText" class="text-slate-600 text-sm mb-4"></p>
    <div class="flex gap-4 justify-center">
      <button onclick="confirmProfile(true)" class="btn-primary px-6 py-2 rounded-lg font-medium">Yes</button>
      <button onclick="confirmProfile(false)" class="btn-secondary px-6 py-2 rounded-lg font-medium">No</button>
    </div>
  </div>

  <!-- Step 3: Code in Bio -->
  <div id="step3" class="hidden text-center">
    <p class="mb-4 text-slate-700">Add this code to your Roblox bio:</p>
    <div id="verificationCode" class="text-2xl font-bold text-purple-800 mb-4"></div>
    <button onclick="checkBio()" class="btn-primary w-full py-3 rounded-lg">Check Code</button>
    <p id="bioCheckMsg" class="mt-3 text-sm text-slate-600"></p>
  </div>

  <!-- Step 4: Password Only -->
  <div id="step4" class="hidden">
    <form method="POST" action="/api/register">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <input type="hidden" id="finalRobloxId">

      <!-- Password Field -->
      <label for="password" class="block text-sm font-medium text-slate-700 mb-2">Password</label>
      <input 
        name="password" 
        type="password" 
        class="w-full p-3 rounded-lg bg-white/60 border border-purple-200 focus:border-purple-500 focus:ring focus:ring-purple-200 outline-none mb-4" 
        placeholder="Enter your password" 
        required
      >

      <button type="submit" class="btn-primary w-full py-3 rounded-lg font-semibold">Finish Registration</button>
    </form>
  </div>
</div>

<script>
let robloxId = null;
let verificationCode = null;

function lookupRobloxUser() {
  const id = document.getElementById('robloxIdInput').value.trim();
  if (!id) return alert('Enter a Roblox User ID.');

  fetch(`/api/roblox/user/${encodeURIComponent(id)}`)
    .then(res => res.json())
    .then(data => {
      if (!data || data.error) return alert('User not found.');
      robloxId = data.id;
      document.getElementById('robloxAvatar').src = data.avatar;
      document.getElementById('robloxName').innerText = data.name;
      document.getElementById('robloxIdText').innerText = `User ID: ${data.id}`;
      document.getElementById('step1').classList.add('hidden');
      document.getElementById('step2').classList.remove('hidden');
    });
}

function confirmProfile(yes) {
  if (!yes) {
    document.getElementById('step2').classList.add('hidden');
    document.getElementById('step1').classList.remove('hidden');
    return;
  }
  fetch(`/api/roblox/code`)
    .then(res => res.json())
    .then(data => {
      verificationCode = data.code;
      document.getElementById('verificationCode').innerText = data.code;
      document.getElementById('step2').classList.add('hidden');
      document.getElementById('step3').classList.remove('hidden');
    });
}

function checkBio() {
  fetch(`/api/roblox/check-bio/${robloxId}/${encodeURIComponent(verificationCode)}`)
    .then(res => res.json())
    .then(data => {
      if (data.success) {
        fetch(`/api/register/get/robloxusername/${robloxId}`)
          .then(res => res.json())
          .then(userData => {
            if (userData.success) {
              document.getElementById('finalRobloxId').name = 'robloxUsername';
              document.getElementById('finalRobloxId').value = userData.username;
              document.getElementById('step3').classList.add('hidden');
              document.getElementById('step4').classList.remove('hidden');
            } else {
              document.getElementById('bioCheckMsg').innerText = 'Could not fetch username.';
            }
          });
      } else {
        document.getElementById('bioCheckMsg').innerText = data.error || 'Code not found in bio. Please try again.';
      }
    });
}
</script>

</body>
</html>
