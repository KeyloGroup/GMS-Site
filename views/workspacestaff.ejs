<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= workspace.name %> Staff â€” Keylo Workspace</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">
  <link rel="icon" href="/assets/keylo-logo.png">

  <style>
    body {
      background-color: #0d0d0d;
      color: #fff;
      font-family: 'Inter', sans-serif;
      overflow-x: hidden;
    }

    .dotted-bg {
      background-image: radial-gradient(#222 1px, transparent 1px);
      background-size: 24px 24px;
    }

    .dotted-bg::before {
      content: "";
      position: absolute;
      inset: 0;
      background: radial-gradient(#1a1a1a 1px, transparent 1px);
      background-size: 24px 24px;
      opacity: 0.5;
      pointer-events: none;
      z-index: 0;
    }

    .card-bg {
      background-color: #111;
      border: 1px solid #1a1a1a;
      border-radius: 12px;
      transition: all 0.2s ease;
    }

    .card-bg:hover {
      border-color: #333;
      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.3);
    }

    .sidebar-link {
      display: flex;
      align-items: center;
      gap: .75rem;
      padding: .75rem .9rem;
      border-radius: .75rem;
      color: #9ca3af;
      font-weight: 500;
      transition: all 0.2s ease;
    }

    .sidebar-link:hover {
      background-color: rgba(255, 255, 255, 0.08);
      color: #fff;
      transform: translateX(4px);
    }

    .sidebar-active {
      background-color: rgba(255, 255, 255, 0.15);
      color: #fff;
      font-weight: 600;
    }

    .sidebar-active:hover {
      transform: translateX(0);
    }

    .scrollbar-hide::-webkit-scrollbar { display: none; }
    .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
    
    .sidebar-link img {
      filter: brightness(0) invert(1);
      transition: filter 0.2s ease;
    }
  </style>
</head>

<body class="text-white flex min-h-screen">

  <!-- Sidebar -->
  <aside class="w-20 md:w-64 p-4 glass flex flex-col shadow-xl sticky top-0 h-screen overflow-y-auto scrollbar-hide">
    <div class="flex flex-col items-center mb-10 flex-shrink-0">
      <img src="<%= workspace.image %>" alt="Workspace Icon" class="w-14 h-14 rounded-full mb-2 shadow-md">
      <p class="text-gray-300 text-sm font-semibold text-center"><%= workspace.name %></p>
    </div>

    <div class="border-t border-gray-700 mb-4"></div>

    <nav class="flex flex-col gap-2 flex-1">
      <a href="/workspace/<%= workspace.id %>/" class="sidebar-link"><img src="/icons/icons8-home-48.png" class="w-5 h-5"><span>Home</span></a>
      <a href="#" class="sidebar-link"><img src="/icons/icons8-checked-box-50.png" class="w-5 h-5"><span>Tasks</span></a>
      <a href="#" class="sidebar-link"><img src="/icons/icons8-open-book-50.png" class="w-5 h-5"><span>Logbook</span></a>
      <a href="/workspace/<%= workspace.id %>/sessions" class="sidebar-link"><img src="/icons/icons8-calendar-50.png" class="w-5 h-5"><span>Sessions</span></a>
      <a href="/workspace/<%= workspace.id %>/staff" class="sidebar-link sidebar-active"><img src="/icons/icons8-avatar-24.png" class="w-5 h-5"><span>Staff</span></a>
      <a href="/workspace/<%= workspace.id %>/activity" class="sidebar-link"><img src="/icons/icons8-clock-24.png" class="w-5 h-5"><span>Activity</span></a>
      <a href="#" class="sidebar-link"><img src="/icons/icons8-airplane-take-off-50.png" class="w-5 h-5"><span>Leave</span></a>
      <a href="#" class="sidebar-link"><img src="/icons/icons8-folder-50.png" class="w-5 h-5"><span>Documents</span></a>
    </nav>

    <div class="border-t border-gray-700 mt-4"></div>

    <a href="/workspace/<%= workspace.id %>/settings" class="sidebar-link mt-4 flex-shrink-0">
      <img src="/icons/icons8-settings-50.png" class="w-5 h-5"><span>Settings</span>
    </a>

    <div class="mt-6 flex items-center gap-3 p-2 glass rounded-xl flex-shrink-0">
      <img src="<%= userProfileURL %>" alt="Profile" class="w-10 h-10 rounded-full shadow">
      <div class="hidden md:block">
        <p class="text-sm font-semibold text-white"><%= user %></p>
        <p class="text-xs text-gray-400">Online</p>
      </div>
    </div>
  </aside>

  <!-- Main Content -->
  <main class="flex-1 p-8 overflow-y-auto relative dotted-bg">
    <header class="flex justify-between items-center mb-12 relative z-10">
      <div>
        <h1 class="text-3xl font-extrabold glow-text">Staff Members</h1>
        <p class="text-gray-400 text-sm">View your staff and their analytics</p>
      </div>
      <div class="flex items-center gap-4">
        <input class="card-bg px-4 py-2 rounded-full placeholder-gray-400 text-white w-64 focus:outline-none focus:ring-2 focus:ring-gray-600 border border-[#333]" placeholder="Search Staff..." />
        <button class="card-bg p-3 rounded-full hover:bg-white/10 transition border border-[#333]">
          <i class="fas fa-bell text-gray-400 hover:text-white"></i>
        </button>
      </div>
    </header>

    <% if (staff && staff.length > 0) { %>
      <section class="grid sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6 relative z-10">
        <% staff.forEach(member => { %>
          <div class="card-bg p-6 text-center cursor-pointer hover:shadow-lg hover:bg-[#151515]">
            <img 
              src="<%= member.avatarUrl || 'https://placehold.co/150x150?text=No+Image' %>" 
              alt="<%= member.username %>" 
              class="w-20 h-20 rounded-full mx-auto mb-3 border border-[#333] shadow"
              data-id="<%= member.id %>"
            >
            <h3 class="font-semibold text-white"><%= member.username %></h3>
            <p class="text-gray-400 text-sm mt-1">
              Rank: <%= member.rankName %> (<%= member.rank %>)
            </p>
          </div>
        <% }) %>
      </section>
    <% } else { %>
      <p class="mt-8 text-gray-400 text-center relative z-10">No staff members found for this workspace.</p>
    <% } %>
  </main>

  <script src="https://kit.fontawesome.com/a076d05399.js" crossorigin="anonymous"></script>
</body>
</html>
