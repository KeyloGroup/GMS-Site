<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&family=Outfit:wght@600;800&display=swap" rel="stylesheet">

  <style>
    body { font-family: 'Inter', sans-serif; }
    h1, h2, h3, h4 { font-family: 'Outfit', sans-serif; }

    .glass {
      background: rgba(255, 255, 255, 0.08);
      backdrop-filter: blur(20px) saturate(200%);
      -webkit-backdrop-filter: blur(20px) saturate(200%);
      border-radius: 22px;
      border: 1px solid rgba(255, 255, 255, 0.15);
      box-shadow: 0 8px 30px rgba(0, 0, 0, 0.1);
    }

    .btn-primary {
      background: linear-gradient(to right, #7e22ce, #9333ea);
      color: white;
      transition: all 0.3s ease;
    }
    .btn-primary:hover {
      background: linear-gradient(to right, #6b21a8, #7e22ce);
    }

    .btn-secondary {
      background: rgba(255, 255, 255, 0.1);
      color: #374151;
    }

    .glow-text {
      text-shadow: 0 0 5px rgba(200, 150, 255, 0.5);
    }
  </style>
</head>
<body class="bg-gradient-to-br from-gray-50 via-purple-50 to-purple-100 text-slate-900">

<!-- Header -->
<header class="fixed w-full glass z-50">
  <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">
    <a href="/" class="text-2xl font-extrabold glow-text text-purple-800">Keylo</a>
    <nav class="hidden md:flex gap-8 text-slate-700">
      <a href="/features" class="hover:text-purple-600">Features</a>
      <a href="/pricing" class="hover:text-purple-600">Pricing</a>
      <a href="/contact" class="hover:text-purple-600">Contact</a>
    </nav>
    <div class="flex gap-3">
      <a href="/login" class="btn-secondary px-4 py-2 rounded-lg font-medium">Log in</a>
      <a href="/waitlist" class="btn-primary px-4 py-2 rounded-lg font-semibold">Get Started</a>
    </div>
  </div>
</header>

<!-- Waitlist Section -->
<section class="min-h-screen flex items-center justify-center pt-32 pb-20">
  <div class="max-w-lg w-full glass p-10 text-center">
    <h1 class="text-4xl font-bold mb-4 glow-text text-purple-800">Join the Waitlist</h1>
    <p class="mb-6 text-slate-700">Be among the first to access Keylo when we launch.</p>

    <% if (typeof success !== 'undefined' && success) { %>
      <div class="p-4 mb-6 rounded-lg bg-green-100 text-green-800">
        ðŸŽ‰ Youâ€™re on the waitlist! Check your email for confirmation.
      </div>
    <% } %>

    <% if (typeof error !== 'undefined') { %>
      <div class="p-4 mb-6 rounded-lg bg-red-100 text-red-800">
        <%= error %>
      </div>
    <% } %>

    <form method="POST" action="/waitlist" class="flex flex-col gap-4">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <input 
        type="email" 
        name="email" 
        required 
        placeholder="Enter your email" 
        class="w-full px-4 py-3 rounded-lg border border-slate-300 focus:ring-2 focus:ring-purple-400"
      >
      <button type="submit" class="btn-primary px-6 py-3 rounded-lg font-semibold">
        Join Waitlist
      </button>
    </form>
  </div>
</section>

<!-- Footer -->
<footer class="bg-gradient-to-br from-purple-900 via-purple-800 to-purple-700 text-white py-12 mt-20">
  <div class="max-w-7xl mx-auto px-6 grid md:grid-cols-4 gap-8">
    <div>
      <h4 class="font-semibold mb-4">Keylo</h4>
      <p class="text-sm">Streamline your community operations with ease and security.</p>
    </div>
    <div>
      <h4 class="font-semibold mb-4">Product</h4>
      <ul class="space-y-2">
        <li><a href="/features" class="hover:text-purple-200">Features</a></li>
        <li><a href="/pricing" class="hover:text-purple-200">Pricing</a></li>
      </ul>
    </div>
    <div>
      <h4 class="font-semibold mb-4">Company</h4>
      <ul class="space-y-2">
        <li><a href="/about" class="hover:text-purple-200">About</a></li>
        <li><a href="/careers" class="hover:text-purple-200">Careers</a></li>
      </ul>
    </div>
    <div>
      <h4 class="font-semibold mb-4">Support</h4>
      <ul class="space-y-2">
        <li><a href="mailto:support@keyloroblox.xyz" class="hover:text-purple-200">support@keyloroblox.xyz/a></li>
        <li><a href="#" class="hover:text-purple-200">Discord Tickets</a></li>
      </ul>
    </div>
  </div>
  <div class="text-center mt-8 text-sm text-purple-200">Â© <%= new Date().getFullYear() %> Keylo. All rights reserved.</div>
</footer>

<script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>
<script> lucide.createIcons(); </script>
</body>
</html>
