<!DOCTYPE html>
<html lang="en" class="scroll-smooth">

<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Keylo — Community Infrastructure</title>

<script src="https://cdn.tailwindcss.com"></script>

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

<link href="https://unpkg.com/aos@next/dist/aos.css" rel="stylesheet">

<style>

body{
font-family:'Inter',sans-serif;
background:#0f1117;
color:#e5e7eb;
}

.navbar{
background:rgba(15,17,23,.85);
backdrop-filter:blur(12px);
border-bottom:1px solid rgba(255,255,255,.06);
}

.btn-primary{
background:#4f46e5;
padding:.75rem 1.6rem;
border-radius:.6rem;
font-weight:600;
color:white;
transition:.2s;
}

.btn-primary:hover{
background:#4338ca;
transform:translateY(-1px);
}

.btn-secondary{
border:1px solid rgba(255,255,255,.15);
padding:.75rem 1.6rem;
border-radius:.6rem;
transition:.2s;
}

.btn-secondary:hover{
background:rgba(255,255,255,.05);
}

.card{
background:#151821;
border:1px solid rgba(255,255,255,.05);
border-radius:1rem;
transition:.25s;
}

.card:hover{
transform:translateY(-4px);
border-color:rgba(255,255,255,.12);
}

.hero-bg{
background:linear-gradient(
180deg,
rgba(79,70,229,.12),
rgba(15,17,23,0)
);
}

</style>
</head>

<body>

<!-- NAVBAR -->

<header class="navbar fixed top-0 w-full z-50">

<div class="max-w-7xl mx-auto px-8 py-4 flex justify-between items-center">

<div class="text-xl font-bold text-white">
Keylo
</div>

<nav class="hidden md:flex gap-8 text-sm text-gray-400">

<a href="#features" class="hover:text-white">Features</a>
<a href="#pricing" class="hover:text-white">Pricing</a>
<a href="#contact" class="hover:text-white">Contact</a>

</nav>

<div class="flex gap-3">

<a href="/login" class="btn-secondary">Login</a>
<a href="/register" class="btn-primary">Get Started</a>

</div>

</div>

</header>

<!-- HERO -->

<section class="hero-bg pt-40 pb-28">

<div class="max-w-7xl mx-auto px-8 grid lg:grid-cols-2 gap-16 items-center">

<div data-aos="fade-up">

<h1 class="text-5xl lg:text-6xl font-extrabold text-white leading-tight">

Community Infrastructure  
for Modern Roblox Groups

</h1>

<p class="mt-6 text-lg text-gray-400 max-w-lg">

Manage, analyze and automate your Roblox communities with powerful infrastructure built for scale.

</p>

<div class="mt-8 flex gap-4">

<a href="#pricing" class="btn-primary">
Get Started
</a>

<a href="#features" class="btn-secondary">
View Features
</a>

</div>

</div>


<!-- DASHBOARD IMAGE -->

<div data-aos="fade-left">

<img
src="/icons/dashprev.png"
class="rounded-xl border border-gray-800 shadow-xl w-full transition duration-500 hover:scale-[1.01]"
alt="Dashboard Preview"
/>

</div>

</div>

</section>

<!-- METRICS -->

<section class="border-t border-gray-800 py-20">

<div class="max-w-6xl mx-auto px-8 grid grid-cols-2 md:grid-cols-4 gap-10 text-center">

<div data-aos="fade-up">

<div class="text-3xl font-bold text-white">1,200+</div>

<p class="text-gray-400 mt-2 text-sm">
Groups Managed
</p>

</div>

<div data-aos="fade-up" data-aos-delay="100">

<div class="text-3xl font-bold text-white">60K+</div>

<p class="text-gray-400 mt-2 text-sm">
Members Tracked
</p>

</div>

<div data-aos="fade-up" data-aos-delay="200">

<div class="text-3xl font-bold text-white">140+</div>

<p class="text-gray-400 mt-2 text-sm">
Automation Systems
</p>

</div>

<div data-aos="fade-up" data-aos-delay="300">

<div class="text-3xl font-bold text-white">24/7</div>

<p class="text-gray-400 mt-2 text-sm">
Infrastructure Monitoring
</p>

</div>

</div>

</section>

<!-- FEATURES -->

<section id="features" class="border-t border-gray-800 py-24">

<div class="max-w-6xl mx-auto px-8">

<h2 class="text-4xl font-bold text-white text-center mb-16" data-aos="fade-up">

Powerful Platform Features

</h2>

<div class="grid md:grid-cols-2 gap-10">

<div class="card p-8" data-aos="fade-up">

<h3 class="text-xl font-semibold text-white">
Instant Setup
</h3>

<p class="text-gray-400 mt-2">
Connect your Roblox group and deploy tools instantly.
</p>

</div>

<div class="card p-8" data-aos="fade-up" data-aos-delay="100">

<h3 class="text-xl font-semibold text-white">
Advanced Analytics
</h3>

<p class="text-gray-400 mt-2">
Track engagement, rank activity and growth metrics.
</p>

</div>

<div class="card p-8" data-aos="fade-up" data-aos-delay="200">

<h3 class="text-xl font-semibold text-white">
Automation Systems
</h3>

<p class="text-gray-400 mt-2">
Reduce manual moderation with automated workflows.
</p>

</div>

<div class="card p-8" data-aos="fade-up" data-aos-delay="300">

<h3 class="text-xl font-semibold text-white">
Secure Infrastructure
</h3>

<p class="text-gray-400 mt-2">
Enterprise-grade protection and stable API connections.
</p>

</div>

</div>

</div>

</section>

<!-- PRICING -->

<section id="pricing" class="border-t border-gray-800 py-24">

<div class="max-w-5xl mx-auto px-8 text-center">

<h2 class="text-4xl font-bold text-white mb-14" data-aos="fade-up">
Pricing
</h2>

<div class="grid md:grid-cols-2 gap-10">

<div class="card p-10" data-aos="fade-right">

<h3 class="text-xl font-semibold text-white mb-4">
Starter
</h3>

<p class="text-4xl font-bold text-white">
Free
</p>

<ul class="mt-6 text-gray-400 text-sm space-y-2">
<li>1 Workspace</li>
<li>Basic Analytics</li>
<li>API Access</li>
</ul>

<button class="btn-secondary w-full mt-8 opacity-60 cursor-not-allowed">
Unavailable
</button>

</div>

<div class="card p-10" data-aos="fade-left">

<h3 class="text-xl font-semibold text-white mb-4">
Pro
</h3>

<p class="text-4xl font-bold text-white">
400 Robux
</p>

<ul class="mt-6 text-gray-400 text-sm space-y-2">
<li>3 Workspaces</li>
<li>Advanced Analytics</li>
<li>Automation Tools</li>
<li>Priority Support</li>
</ul>

<button class="btn-primary w-full mt-8">
Unavailable
</button>

</div>

</div>

</div>

</section>

<!-- CTA -->

<section class="border-t border-gray-800 py-20 text-center">

<h2 class="text-4xl font-bold text-white mb-4" data-aos="zoom-in">
Simplify Your Community Operations
</h2>

<p class="text-gray-400 mb-6" data-aos="zoom-in" data-aos-delay="100">
Infrastructure designed for modern Roblox groups.
</p>

<a href="/register" class="btn-primary" data-aos="zoom-in" data-aos-delay="200">
Create Account
</a>

</section>

<!-- FOOTER -->

<footer id="contact" class="border-t border-gray-800 py-12 text-gray-400 text-sm">

<div class="max-w-7xl mx-auto px-8 grid md:grid-cols-4 gap-10">

<div>
<h4 class="text-white font-semibold mb-3">Product</h4>
<p>Features</p>
<p>Pricing</p>
</div>

<div>
<h4 class="text-white font-semibold mb-3">Company</h4>
<p>About</p>
<p>Careers</p>
</div>

<div>
<h4 class="text-white font-semibold mb-3">Support</h4>
<p>team@keylogroup.co.uk</p>
<p>Discord Tickets</p>
</div>

<div>
<h4 class="text-white font-semibold mb-3">Legal</h4>
<p>Privacy Policy</p>
<p>Terms of Service</p>
</div>

</div>

<div class="text-center text-gray-500 mt-10">
© <%= new Date().getFullYear() %> Keylo
</div>

</footer>

<script src="https://unpkg.com/aos@next/dist/aos.js"></script>

<script>
AOS.init({
duration:700,
easing:"ease-out-cubic",
once:false,
mirror:true
});
</script>

</body>
</html>
