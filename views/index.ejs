<section class="py-40 relative px-6 overflow-hidden">
    <div class="absolute inset-0 bg-indigo-600/5"></div>
    <div class="max-w-4xl mx-auto text-center relative z-10">
        <h2 class="text-4xl md:text-5xl font-extrabold mb-8">Ready to Professionalize <br>Your Community?</h2>
        <a href="/register" class="btn-primary px-10 py-5 rounded-full font-bold text-xl inline-block hover:shadow-indigo-500/50 transition">Get Started Today</a>
