    }

    .divider { border-top: 1px solid #1a1a1a; }

    .dotted-bg {
      background-image: radial-gradient(#222 1px, transparent 1px);
      background-size: 24px 24px;
    }
    .dotted-bg::before {
      content: "";
      position: absolute;
      inset: 0;
      background: radial-gradient(#1a1a1a 1px, transparent 1px);
      background-size: 24px 24px;
      opacity: 0.5;
      pointer-events: none;
      z-index: 0;
    }
  </style>
</head>

