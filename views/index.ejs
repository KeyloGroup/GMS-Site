<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Keylo – Premium Community Management</title>

  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/@vengeanceui/core@latest/dist/vengeance.min.js"></script>

  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap"
    rel="stylesheet"
  />
  <link rel="icon" href="/assets/keylo-logo.png">

  <style>
    body {
      background-color: #0d0d0d;
      color: #fff;
      font-family: "Inter", sans-serif;
      overflow-x: hidden;
    }

    .glass-nav {
      backdrop-filter: blur(12px);
      background: rgba(13, 13, 13, 0.65);
      border-bottom: 1px solid #222;
    }
  </style>
</head>

<body class="flex flex-col min-h-screen text-white">

  <!-- NAVBAR – GLASS -->
  <header class="fixed w-full z-50 glass-nav">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 py-4 flex items-center justify-between">
      <a href="/" class="text-2xl font-extrabold">Keylo</a>

      <nav class="hidden md:flex gap-8 text-gray-300 uppercase tracking-wide text-sm">
        <a href="#features" class="hover:text-white transition">Features</a>
        <a href="#services" class="hover:text-white transition">Services</a>
        <a href="#pricing" class="hover:text-white transition">Pricing</a>
        <a href="#contact" class="hover:text-white transition">Contact</a>
      </nav>

      <div class="flex items-center gap-4">
        <a href="/register" class="btn btn-primary btn-lg">Get Started</a>
        <a href="/login" class="btn btn-outline btn-lg">Login</a>
      </div>
    </div>
  </header>

  <!-- HERO -->
  <section class="pt-28 pb-24 text-center relative">
    <div class="max-w-6xl mx-auto px-6 grid md:grid-cols-2 gap-12 items-center">
      <div class="space-y-6">
        <h1 class="text-5xl lg:text-6xl font-extrabold leading-tight">
          Built for Modern Roblox Community Leaders
        </h1>
        <p class="text-lg text-gray-400 max-w-lg">
          Smart automation, deep analytics, and effortless control — all in one place.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="#pricing" class="btn btn-primary btn-xl">View Plans</a>
          <button onclick="openModal('videoModal')" class="btn btn-outline btn-xl">
            Watch Demo
          </button>
        </div>
      </div>

      <div class="relative">
        <div
          class="rounded-3xl overflow-hidden ring-2 ring-gray-800 shadow-2xl transform hover:scale-105 transition"
        >
          <img src="/icons/dashprev.png" alt="Dashboard Preview" class="w-full" />
        </div>
      </div>
    </div>
  </section>

  <hr class="border-gray-800">

  <!-- SERVICES -->
  <section id="services" class="py-20">
    <div class="max-w-6xl mx-auto px-6 text-center space-y-10">
      <h2 class="text-3xl font-bold">What Keylo Excels At</h2>

      <div class="grid grid-cols-1 md:grid-cols-5 gap-8 text-gray-300">
        <!-- CARD -->
        <div class="space-y-3">
          <h3 class="text-white font-semibold">Group Leader Tools</h3>
          <p class="text-sm">Effortless control over roles, ranks and permissions.</p>
        </div>

        <div class="space-y-3">
          <h3 class="text-white font-semibold">Step‑by‑Step Setup</h3>
          <p class="text-sm">Guided flows that get you running fast.</p>
        </div>

        <div class="space-y-3">
          <h3 class="text-white font-semibold">Real‑Time Analytics</h3>
          <p class="text-sm">Insights that help your community grow.</p>
        </div>

        <div class="space-y-3">
          <h3 class="text-white font-semibold">Multi‑Device Access</h3>
          <p class="text-sm">Manage from phone, tablet or desktop.</p>
        </div>

        <div class="space-y-3">
          <h3 class="text-white font-semibold">Automation at Scale</h3>
          <p class="text-sm">Cut repetitive work, boost productivity.</p>
        </div>
      </div>
    </div>
  </section>

  <hr class="border-gray-800">

  <!-- FEATURES -->
  <section id="features" class="py-24">
    <div class="max-w-6xl mx-auto px-6 grid md:grid-cols-2 gap-10">
      <!-- FEATURE CARD -->
      <div class="bg-[#111] p-8 rounded-2xl shadow-xl hover:shadow-2xl transition">
        <h3 class="text-xl font-semibold">Instant Setup</h3>
        <p class="text-gray-400 mt-2">Get started in seconds — no friction.</p>
      </div>

      <div class="bg-[#111] p-8 rounded-2xl shadow-xl hover:shadow-2xl transition">
        <h3 class="text-xl font-semibold">Secure & Reliable</h3>
        <p class="text-gray-400 mt-2">Enterprise‑grade security you can trust.</p>
      </div>

      <div class="bg-[#111] p-8 rounded-2xl shadow-xl hover:shadow-2xl transition">
        <h3 class="text-xl font-semibold">Analytics That Matter</h3>
        <p class="text-gray-400 mt-2">Clear charts, real insights.</p>
      </div>

      <div class="bg-[#111] p-8 rounded-2xl shadow-xl hover:shadow-2xl transition">
        <h3 class="text-xl font-semibold">Automations Engine</h3>
        <p class="text-gray-400 mt-2">Automation that scales with your community.</p>
      </div>
    </div>
  </section>

  <hr class="border-gray-800">

  <!-- PRICING -->
  <section id="pricing" class="py-24">
    <div class="max-w-5xl mx-auto px-6 text-center space-y-12">
      <h2 class="text-4xl font-bold">Straightforward Pricing</h2>

      <div class="grid md:grid-cols-2 gap-10">
        <!-- FREE -->
        <div class="bg-[#111] p-10 rounded-2xl border border-gray-700 shadow-lg">
          <h3 class="text-2xl font-semibold mb-2">Starter</h3>
          <p class="text-5xl font-bold">0 GBP</p>
          <ul class="text-gray-400 text-sm space-y-2 mt-4 list-disc list-inside">
            <li>1 Workspace</li>
            <li>Basic API & Logs</li>
            <li>Community Tools</li>
          </ul>
          <button class="btn btn-outline btn-lg mt-6 w-full opacity-50 cursor-not-allowed">Unavailable</button>
        </div>

        <!-- PRO -->
        <div class="bg-[#111] p-10 rounded-2xl border-2 border-indigo-600 shadow-2xl transform hover:scale-105 transition">
          <h3 class="text-2xl font-semibold mb-2">Pro</h3>
          <p class="text-5xl font-bold">400 robux</p>
          <ul class="text-gray-300 text-sm space-y-2 mt-4 list-disc list-inside">
            <li>All Starter Features</li>
            <li>3 Workspaces</li>
            <li>Advanced Graphs & API</li>
            <li>Auto‑Ranking Included</li>
          </ul>
          <button class="btn btn-primary btn-lg mt-6 w-full">Unavailable</button>
        </div>
      </div>
    </div>
  </section>

  <hr class="border-gray-800">

  <!-- CTA -->
  <section class="py-20 text-center">
    <h2 class="text-4xl font-bold mb-4">Ready to Upgrade Your Workflow?</h2>
    <p class="text-gray-400 mb-6">Start saving time today with Keylo.</p>
    <a href="/register" class="btn btn-primary btn-xl">Get Started</a>
  </section>

  <hr class="border-gray-800">

  <!-- FOOTER -->
  <footer id="contact" class="py-12 text-gray-400 text-sm text-center space-y-6">
    <div class="max-w-6xl mx-auto px-6 grid md:grid-cols-4 gap-6">
      <div class="space-y-2">
        <h4 class="text-white font-semibold">Product</h4>
        <p>Features, Services, Pricing</p>
      </div>
      <div class="space-y-2">
        <h4 class="text-white font-semibold">Company</h4>
        <p>About • FAQ</p>
      </div>
      <div class="space-y-2">
        <h4 class="text-white font-semibold">Support</h4>
        <p>team@keylogroup.co.uk</p>
        <p>Discord Tickets</p>
      </div>
      <div class="space-y-2">
        <h4 class="text-white font-semibold">Legal</h4>
        <p>Terms • Privacy</p>
      </div>
    </div>
    <div class="mt-8 text-gray-600">
      © <%= new Date().getFullYear() %> Keylo. All rights reserved.
    </div>
  </footer>

  <!-- Video Modal (kept same) -->
  <script>
    function openModal(id) {
      const el = document.getElementById(id);
      el.classList.remove("hidden");
      el.classList.add("flex");
    }
    function closeModal(id) {
      const el = document.getElementById(id);
      el.classList.add("hidden");
      el.classList.remove("flex");
    }
  </script>

</body>
</html>
