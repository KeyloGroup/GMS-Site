        </div>
        <h1 data-aos="fade-up" data-aos-delay="100" class="text-5xl md:text-7xl font-extrabold tracking-tight mb-6">
            Scaling Roblox Communities <br><span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-400 to-cyan-400">Without the Friction.</span>
        </h1>
        <p data-aos="fade-up" data-aos-delay="200" class="text-lg text-gray-400 max-w-2xl mx-auto mb-10 leading-relaxed">
            Keylo delivers enterprise-grade automation and high-fidelity analytics for serious group owners. Manage ranks, track performance, and automate workflows from one central dashboard.
        </p>
        <div data-aos="fade-up" data-aos-delay="300" class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="/register" class="btn-primary px-8 py-4 rounded-xl font-bold text-lg hover:scale-105 transition">Deploy Keylo Now</a>
            <a href="#features" class="bg-white/5 hover:bg-white/10 border border-white/10 px-8 py-4 rounded-xl font-bold text-lg transition">Explore Features</a>
        </div>
    </div>

    <div data-aos="zoom-in-up" data-aos-delay="400" class="max-w-6xl mx-auto mt-20 relative">
        <div class="absolute -inset-1 bg-gradient-to-r from-indigo-500 to-cyan-500 rounded-2xl blur opacity-20"></div>
        <div class="relative bg-[#0d0d0d] rounded-2xl border border-white/10 overflow-hidden shadow-2xl">
            <img src="/icons/dashprev.png" alt="Keylo Dashboard Interface" class="w-full opacity-90">
        </div>
    </div>
</section>

<section class="py-10 border-y border-white/5 bg-white/[0.01]">
