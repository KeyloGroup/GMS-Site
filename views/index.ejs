<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Keylo</title>

<!-- Tailwind + Vengeance Core -->
<script src="https://cdn.tailwindcss.com"></script>
<script src="https://unpkg.com/@vengeanceui/core@latest/dist/vengeance.min.js"></script>

<!-- AOS for scroll animations -->
<link href="https://unpkg.com/aos@next/dist/aos.css" rel="stylesheet">

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">
<link rel="icon" href="/assets/keylo-logo.png">

<style>
body {
  background: #0d0d0d;
  color: #fff;
  font-family: 'Inter', sans-serif;
}
.glass-nav {
  background: rgba(10, 10, 10, 0.5);
  backdrop-filter: blur(14px);
  border-bottom: 1px solid #222;
}
</style>
</head>

<body class="relative">

<!-- NAVBAR -->
<header class="fixed top-0 w-full z-50 glass-nav shadow-lg">
  <div class="max-w-7xl mx-auto px-8 py-5 flex items-center justify-between">
    <a href="/" class="text-2xl font-bold tracking-tight">Keylo</a>

    <nav class="hidden lg:flex gap-8 text-gray-300 text-sm font-semibold uppercase">
      <a href="#features" class="hover:text-white transition">Features</a>
      <a href="#services" class="hover:text-white transition">Services</a>
      <a href="#pricing" class="hover:text-white transition">Pricing</a>
      <a href="#contact" class="hover:text-white transition">Contact</a>
    </nav>

    <div class="flex items-center gap-4">
      <a href="/register" class="btn btn-primary btn-md">Get Started</a>
      <a href="/login" class="btn btn-outline btn-md">Login</a>
    </div>
  </div>
</header>

<!-- HERO -->
<section class="pt-32 pb-20">
  <div class="max-w-7xl mx-auto px-8 grid lg:grid-cols-2 gap-12 items-center">
    <div data-aos="fade-right" data-aos-delay="200" class="space-y-6">
      <h1 class="text-5xl lg:text-6xl font-extrabold leading-tight">
        Command Your Roblox Community<br>
        with Clarity & Control
      </h1>
      <p class="text-xl text-gray-400 max-w-lg">
        Smart automation, deep analytics, and effortless management — powered by beautiful, intuitive UI.
      </p>

      <div class="flex gap-4 pt-4">
        <a href="#pricing" class="btn btn-primary btn-xl">View Plans</a>
        <button onclick="openModal('videoModal')" class="btn btn-outline btn-xl">Watch Demo</button>
      </div>
    </div>

    <div data-aos="fade-left" data-aos-delay="400">
      <div class="relative group">
        <div class="rounded-3xl overflow-hidden ring-2 ring-indigo-700 group-hover:scale-105 transition duration-500 shadow-2xl">
          <img src="/icons/dashprev.png" alt="Dashboard Preview" class="w-full">
        </div>
      </div>
    </div>
  </div>
</section>

<hr class="border-gray-800">

<!-- SERVICES -->
<section id="services" class="py-20">
  <div class="max-w-6xl mx-auto px-8 text-center space-y-8">
    <h2 data-aos="fade-up" class="text-3xl font-bold">What Keylo Helps You Do Best</h2>

    <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-5 gap-8 text-gray-300 mt-10">
      <div data-aos="fade-up" data-aos-delay="100" class="space-y-2">
        <h3 class="text-white font-semibold">Leader Tools</h3>
        <p class="text-sm">Manage roles and permissions effortlessly.</p>
      </div>
      <div data-aos="fade-up" data-aos-delay="200" class="space-y-2">
        <h3 class="text-white font-semibold">Step Setup</h3>
        <p class="text-sm">Quick guided onboarding for teams.</p>
      </div>
      <div data-aos="fade-up" data-aos-delay="300" class="space-y-2">
        <h3 class="text-white font-semibold">Real Insight</h3>
        <p class="text-sm">Analytics that actually inform decisions.</p>
      </div>
      <div data-aos="fade-up" data-aos-delay="400" class="space-y-2">
        <h3 class="text-white font-semibold">Anywhere Access</h3>
        <p class="text-sm">Desktop or mobile — always synced.</p>
      </div>
      <div data-aos="fade-up" data-aos-delay="500" class="space-y-2">
        <h3 class="text-white font-semibold">Automate Workflows</h3>
        <p class="text-sm">Let Keylo take repetitive tasks off your plate.</p>
      </div>
    </div>
  </div>
</section>

<hr class="border-gray-800">

<!-- FEATURES -->
<section id="features" class="py-24 bg-[#0f0f0f]">
  <div class="max-w-6xl mx-auto px-8 space-y-10">
    <h2 data-aos="fade-up" class="text-4xl font-bold text-center">Everything You Need</h2>

    <div class="grid md:grid-cols-2 gap-12">
      <div data-aos="flip-left" class="feature-card p-8 bg-[#111] rounded-3xl shadow-xl transition transform hover:-translate-y-2">
        <h3 class="text-xl font-semibold">Instant Setup</h3>
        <p class="text-gray-400 mt-2">Get started in seconds — no friction.</p>
      </div>

      <div data-aos="flip-right" class="feature-card p-8 bg-[#111] rounded-3xl shadow-xl transition transform hover:-translate-y-2">
        <h3 class="text-xl font-semibold">Secure & Reliable</h3>
        <p class="text-gray-400 mt-2">Enterprise‑grade security you can trust.</p>
      </div>

      <div data-aos="flip-left" class="feature-card p-8 bg-[#111] rounded-3xl shadow-xl transition transform hover:-translate-y-2">
        <h3 class="text-xl font-semibold">Deep Analytics</h3>
        <p class="text-gray-400 mt-2">Charts that tell real stories.</p>
      </div>

      <div data-aos="flip-right" class="feature-card p-8 bg-[#111] rounded-3xl shadow-xl transition transform hover:-translate-y-2">
        <h3 class="text-xl font-semibold">Powerful Automation</h3>
        <p class="text-gray-400 mt-2">Cut manual work across your groups.</p>
      </div>
    </div>
  </div>
</section>

<hr class="border-gray-800">

<!-- PRICING -->
<section id="pricing" class="py-24">
  <div class="max-w-5xl mx-auto px-8 text-center space-y-10">
    <h2 data-aos="fade-up" class="text-4xl font-bold">Flexible & Clear Pricing</h2>

    <div class="grid md:grid-cols-2 gap-10">
      <div data-aos="fade-right" class="bg-[#111] p-10 rounded-3xl border border-gray-700 shadow-lg transition-transform hover:scale-105">
        <h3 class="text-2xl font-semibold mb-4">Starter</h3>
        <p class="text-5xl font-bold">0 GBP</p>
        <ul class="text-gray-400 text-sm space-y-2 mt-4 list-disc list-inside">
          <li>1 Workspace</li>
          <li>Basic API, Logs & Docs</li>
          <li>Support Center Access</li>
        </ul>
        <button class="btn btn-outline btn-lg mt-6 w-full opacity-60 cursor-not-allowed">Unavailable</button>
      </div>

      <div data-aos="fade-left" class="bg-[#111] p-12 rounded-3xl border-2 border-indigo-700 shadow-2xl transform hover:scale-105 transition">
        <h3 class="text-2xl font-semibold mb-4">Pro</h3>
        <p class="text-5xl font-bold">400 robux</p>
        <ul class="text-gray-300 text-sm space-y-2 mt-4 list-disc list-inside">
          <li>Everything in Starter</li>
          <li>3 Workspaces</li>
          <li>Advanced Graphs & API</li>
          <li>Auto‑Ranking Included</li>
        </ul>
        <button class="btn btn-primary btn-lg mt-6 w-full">Unavailable</button>
      </div>
    </div>
  </div>
</section>

<hr class="border-gray-800">

<!-- CTA -->
<section class="py-20 text-center">
  <h2 data-aos="zoom-in" class="text-4xl font-bold mb-4">Time to Simplify Your Workflow?</h2>
  <p data-aos="zoom-in" data-aos-delay="200" class="text-gray-400 mb-6">Upgrade your Roblox community management today.</p>
  <a data-aos="zoom-in" data-aos-delay="400" href="/register" class="btn btn-primary btn-xl">Get Started</a>
</section>

<hr class="border-gray-800">

<!-- FOOTER -->
<footer id="contact" class="py-12 text-gray-400 text-sm">
  <div class="max-w-7xl mx-auto px-8 grid md:grid-cols-4 gap-10">
    <div>
      <h4 class="text-white font-semibold mb-3">Product</h4>
      <p>Features • Services • Pricing</p>
    </div>

    <div>
      <h4 class="text-white font-semibold mb-3">Company</h4>
      <p>About • FAQ • Careers</p>
    </div>

    <div>
      <h4 class="text-white font-semibold mb-3">Support</h4>
      <p>team@keylogroup.co.uk</p>
      <p>Discord Tickets</p>
    </div>

    <div>
      <h4 class="text-white font-semibold mb-3">Legal</h4>
      <p>Privacy • Terms</p>
    </div>
  </div>

  <div class="mt-8 text-center text-gray-600">
    © <%= new Date().getFullYear() %> Keylo. All rights reserved.
  </div>
</footer>

<!-- Video Modal -->
<script>
function openModal(id){const el=document.getElementById(id);el.classList.remove("hidden");el.classList.add("flex")}
function closeModal(id){const el=document.getElementById(id);el.classList.add("hidden");el.classList.remove("flex")}
</script>

<!-- AOS Init -->
<script src="https://unpkg.com/aos@next/dist/aos.js"></script>
<script>
AOS.init({
  duration: 800,
  once: true,
});
</script>

</body>
</html>

