<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Keylo — Command Your Community</title>

<script src="https://cdn.tailwindcss.com"></script>
<link href="https://unpkg.com/aos@next/dist/aos.css" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">
<link rel="icon" href="/assets/keylo-logo.png">

<style>
/* Global */
body {
  font-family: 'Inter', sans-serif;
  background: linear-gradient(135deg, #0d0d0d, #111217);
  color: #fff;
  overflow-x: hidden;
}

/* Glass navbar */
.glass-nav {
  backdrop-filter: blur(25px);
  background: rgba(13,13,13,0.55);
  border-bottom: 1px solid rgba(255,255,255,0.08);
}

/* Gradient Buttons */
.gradient-btn {
  background: linear-gradient(90deg,#00f0ff,#5c6ac4,#8a3ffc);
  color:black;
  font-weight: 600;
  border-radius: 0.75rem;
  padding: 0.75rem 2rem;
  transition: all 0.3s ease;
}
.gradient-btn:hover{
  transform: scale(1.05);
  box-shadow: 0 20px 40px rgba(0,240,255,0.4);
}

/* Glass cards */
.glass-card {
  background: rgba(20,20,30,0.6);
  border: 1px solid rgba(255,255,255,0.1);
  backdrop-filter: blur(15px);
  border-radius: 1rem;
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}
.glass-card:hover{
  transform: translateY(-10px);
  box-shadow: 0 20px 40px rgba(0,200,255,0.3);
}

/* Gradient animated headline */
.gradient-text {
  background: linear-gradient(90deg,#00f0ff,#5c6ac4,#8a3ffc);
  -webkit-background-clip: text;
  color: transparent;
  animation: gradientMove 3s ease infinite alternate;
}
@keyframes gradientMove {
  0% { background-position: 0% 50%; }
  100% { background-position: 100% 50%; }
}

/* Floating shapes */
.floating-shape{
  position: absolute;
  border-radius: 50%;
  opacity: 0.15;
  animation: float 6s ease-in-out infinite alternate;
}
@keyframes float{
  0%{transform:translateY(0) rotate(0deg);}
  100%{transform:translateY(-20px) rotate(20deg);}
}

/* Metrics count up */
.counter { font-weight: 700; font-size: 2.5rem; color:#00f0ff; }
</style>
</head>
<body>

<!-- NAVBAR -->
<header class="fixed top-0 w-full z-50 glass-nav">
  <div class="max-w-7xl mx-auto px-8 py-5 flex items-center justify-between">
    <a href="/" class="text-2xl font-bold tracking-tight">Keylo</a>
    <nav class="hidden lg:flex gap-8 text-gray-300 text-sm font-semibold uppercase">
      <a href="#features" class="hover:text-white transition">Features</a>
      <a href="#services" class="hover:text-white transition">Services</a>
      <a href="#pricing" class="hover:text-white transition">Pricing</a>
      <a href="#contact" class="hover:text-white transition">Contact</a>
    </nav>
    <div class="flex items-center gap-4">
      <a href="/register" class="gradient-btn">Get Started</a>
      <a href="/login" class="border-2 border-white px-6 py-2 rounded-lg hover:bg-gray-900 transition">Login</a>
    </div>
  </div>
</header>

<!-- HERO -->
<section class="relative pt-36 pb-32 overflow-hidden">
  <!-- floating shapes -->
  <div class="floating-shape w-64 h-64 bg-cyan-500 top-10 left-10"></div>
  <div class="floating-shape w-48 h-48 bg-purple-500 top-40 right-32"></div>
  <div class="floating-shape w-32 h-32 bg-indigo-500 top-60 left-1/2"></div>

  <div class="max-w-7xl mx-auto px-8 grid lg:grid-cols-2 gap-12 items-center relative z-10">
    <div data-aos="fade-right">
      <h1 class="text-5xl lg:text-6xl font-extrabold tracking-tight gradient-text">
        Master Your Community
      </h1>
      <p class="text-xl text-gray-300 max-w-lg mt-4">
        Automate, analyze, and grow your Roblox community with a sleek, premium interface.
      </p>
      <div class="flex gap-4 pt-6">
        <a href="#pricing" class="gradient-btn shadow-lg">View Plans</a>
        <button onclick="openModal('videoModal')" class="border-2 border-cyan-400 text-cyan-400 hover:bg-cyan-500 hover:text-black px-8 py-3 rounded-lg transition">Watch Demo</button>
      </div>
    </div>
    <div data-aos="fade-left" class="relative z-10">
      <img src="/icons/dashprev.png" alt="Dashboard Preview" class="rounded-3xl shadow-xl hover:scale-105 transition duration-500">
    </div>
  </div>
</section>

<hr class="border-gray-700">

<!-- METRICS -->
<section class="py-20 bg-[#111217]">
  <div class="max-w-6xl mx-auto px-8 text-center grid grid-cols-2 md:grid-cols-4 gap-10">
    <div data-aos="fade-up">
      <div class="counter" data-target="1000">0</div>
      <p class="text-gray-300 mt-2">Active Groups</p>
    </div>
    <div data-aos="fade-up" data-aos-delay="100">
      <div class="counter" data-target="50000">0</div>
      <p class="text-gray-300 mt-2">Members Managed</p>
    </div>
    <div data-aos="fade-up" data-aos-delay="200">
      <div class="counter" data-target="120">0</div>
      <p class="text-gray-300 mt-2">Automations</p>
    </div>
    <div data-aos="fade-up" data-aos-delay="300">
      <div class="counter" data-target="24">0</div>
      <p class="text-gray-300 mt-2">/7 Support</p>
    </div>
  </div>
</section>

<hr class="border-gray-700">

<!-- FEATURES -->
<section id="features" class="py-24">
  <div class="max-w-6xl mx-auto px-8 space-y-10">
    <h2 data-aos="fade-up" class="text-4xl font-bold text-center text-white">Everything You Need</h2>
    <div class="grid md:grid-cols-2 gap-12">
      <div data-aos="flip-left" class="glass-card p-8">
        <h3 class="text-xl font-semibold text-cyan-400">Instant Setup</h3>
        <p class="text-gray-300 mt-2">Get started in seconds — no friction.</p>
      </div>
      <div data-aos="flip-right" class="glass-card p-8">
        <h3 class="text-xl font-semibold text-indigo-400">Secure & Reliable</h3>
        <p class="text-gray-300 mt-2">Enterprise-grade security you can trust.</p>
      </div>
      <div data-aos="flip-left" class="glass-card p-8">
        <h3 class="text-xl font-semibold text-purple-400">Deep Analytics</h3>
        <p class="text-gray-300 mt-2">Charts that tell real stories.</p>
      </div>
      <div data-aos="flip-right" class="glass-card p-8">
        <h3 class="text-xl font-semibold text-teal-400">Powerful Automation</h3>
        <p class="text-gray-300 mt-2">Cut manual work across your groups.</p>
      </div>
    </div>
  </div>
</section>

<hr class="border-gray-700">

<!-- PRICING -->
<section id="pricing" class="py-24">
  <div class="max-w-5xl mx-auto px-8 text-center space-y-10">
    <h2 data-aos="fade-up" class="text-4xl font-bold text-white">Flexible & Clear Pricing</h2>
    <div class="grid md:grid-cols-2 gap-10">
      <div data-aos="fade-right" class="glass-card p-10 border-cyan-400">
        <h3 class="text-2xl font-semibold mb-4 text-cyan-400">Starter</h3>
        <p class="text-5xl font-bold">0 GBP</p>
        <ul class="text-gray-300 text-sm space-y-2 mt-4 list-disc list-inside">
          <li>1 Workspace</li>
          <li>Basic API, Logs & Docs</li>
          <li>Support Center Access</li>
        </ul>
        <button class="btn border-2 border-gray-500 text-gray-300 mt-6 w-full opacity-50 cursor-not-allowed rounded-lg">Unavailable</button>
      </div>
      <div data-aos="fade-left" class="glass-card p-12 border-indigo-500 shadow-2xl">
        <h3 class="text-2xl font-semibold mb-4 text-indigo-400">Pro</h3>
        <p class="text-5xl font-bold">400 robux</p>
        <ul class="text-gray-300 text-sm space-y-2 mt-4 list-disc list-inside">
          <li>Everything in Starter</li>
          <li>3 Workspaces</li>
          <li>Advanced Graphs & API</li>
          <li>Auto-Ranking Included</li>
        </ul>
        <button class="gradient-btn mt-6 w-full">Unavailable</button>
      </div>
    </div>
  </div>
</section>

<hr class="border-gray-700">

<!-- CTA -->
<section class="py-20 text-center">
  <h2 data-aos="zoom-in" class="text-4xl font-bold mb-4 text-white">Time to Simplify Your Workflow?</h2>
  <p data-aos="zoom-in" data-aos-delay="200" class="text-gray-300 mb-6">Upgrade your Roblox community management today.</p>
  <a data-aos="zoom-in" data-aos-delay="400" href="/register" class="gradient-btn shadow-lg">Get Started</a>
</section>

<hr class="border-gray-700">

<!-- FOOTER -->
<footer id="contact" class="py-12 text-gray-400 text-sm">
  <div class="max-w-7xl mx-auto px-8 grid md:grid-cols-4 gap-10">
    <div>
      <h4 class="text-white font-semibold mb-3">Product</h4>
      <p>Features • Services • Pricing</p>
    </div>
    <div>
      <h4 class="text-white font-semibold mb-3">Company</h4>
      <p>About • FAQ • Careers</p>
    </div>
    <div>
      <h4 class="text-white font-semibold mb-3">Support</h4>
      <p>team@keylogroup.co.uk</p>
      <p>Discord Tickets</p>
    </div>
    <div>
      <h4 class="text-white font-semibold mb-3">Legal</h4>
      <p>Privacy • Terms</p>
    </div>
  </div>
  <div class="mt-8 text-center text-gray-500">© <%= new Date().getFullYear() %> Keylo. All rights reserved.</div>
</footer>

<!-- Video Modal -->
<div id="videoModal" class="fixed inset-0 bg-black/80 hidden items-center justify-center p-4 z-50">
  <div class="bg-[#111] max-w-3xl w-full relative rounded-xl border border-[#1c1c1c]">
    <button onclick="closeModal('videoModal')" class="absolute top-3 right-3 text-gray-400 hover:text-white text-2xl leading-none">X</button>
    <div class="p-6">
      <h3 class="text-2xl font-bold mb-4 text-center">Watch Our Demo</h3>
      <div class="aspect-video">
        <iframe src="https://www.youtube.com/embed/dQw4w9WgXcQ" class="w-full h-full rounded-xl" frameborder="0" allowfullscreen loading="lazy"></iframe>
      </div>
    </div>
  </div>
</div>

<script>
function openModal(id){document.getElementById(id).classList.remove("hidden");document.getElementById(id).classList.add("flex")}
function closeModal(id){document.getElementById(id).classList.add("hidden");document.getElementById(id).classList.remove("flex")}

// Counter animation
const counters = document.querySelectorAll('.counter');
counters.forEach(counter=>{
  counter.innerText='0';
  const updateCounter=()=>{
    const target = +counter.getAttribute('data-target');
    const count = +counter.innerText;
    const increment = target/100;
    if(count<target){
      counter.innerText=Math.ceil(count+increment);
      setTimeout(updateCounter,20);
    }else{counter.innerText=target;}
  }
  updateCounter();
});
</script>

<script src="https://unpkg.com/aos@next/dist/aos.js"></script>
<script>
AOS.init({duration:900,easing:'ease-out-cubic',once:false,mirror:true});
</script>

</body>
</html>
