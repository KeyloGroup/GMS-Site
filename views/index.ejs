        <span class="font-bold text-xl uppercase tracking-widest italic">Nexus Global</span>
        <span class="font-bold text-xl uppercase tracking-widest italic">Aegis Roleplay</span>
        <span class="font-bold text-xl uppercase tracking-widest italic">Nova Hotels</span>
