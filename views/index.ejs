<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Keylo</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&family=Outfit:wght@600;800&display=swap" rel="stylesheet">

  <style>
    body { font-family: 'Inter', sans-serif; }
    h1, h2, h3, h4 { font-family: 'Outfit', sans-serif; }

    .glass {
      background: rgba(255, 255, 255, 0.08);
      backdrop-filter: blur(20px) saturate(200%);
      -webkit-backdrop-filter: blur(20px) saturate(200%);
      border-radius: 22px;
      border: 1px solid rgba(255, 255, 255, 0.15);
      box-shadow: 0 8px 30px rgba(0, 0, 0, 0.1);
    }

    .btn-primary {
      background: linear-gradient(to right, #7e22ce, #9333ea);
      color: white;
      transition: all 0.3s ease;
    }
    .btn-primary:hover {
      background: linear-gradient(to right, #6b21a8, #7e22ce);
    }
    .btn-secondary {
      background: rgba(255, 255, 255, 0.1);
      color: #374151;
      transition: all 0.3s ease;
    }
    .btn-secondary:hover {
      background: rgba(255, 255, 255, 0.2);
    }

    .glow-text {
      text-shadow: 0 0 5px rgba(200, 150, 255, 0.5);
    }
  </style>
</head>
<body class="bg-gradient-to-br from-gray-50 via-purple-50 to-purple-100 text-slate-900">

<!-- Header -->
<header class="fixed w-full glass z-50">
  <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">
    <a href="/" class="text-2xl font-extrabold glow-text text-purple-800">Keylo</a>
    <nav class="hidden md:flex gap-6 text-slate-700">
      <a href="#features" class="hover:text-purple-600">Features</a>
      <a href="#pricing" class="hover:text-purple-600">Pricing</a>
      <a href="#contact" class="hover:text-purple-600">Contact</a>
    </nav>
    <div class="flex gap-4">
      <a href="/register" class="btn-primary px-4 py-2 rounded-lg font-semibold">Get Started</a>
      <a href="/login" class="btn-secondary px-4 py-2 rounded-lg font-semibold">Login</a>
    </div>
  </div>
</header>

<!-- Hero -->
<section class="relative min-h-screen flex flex-col justify-center items-center text-center pt-32 pb-20 bg-gradient-to-br from-purple-100 via-white to-purple-50">
  <div class="max-w-3xl mx-auto px-6">
    <h1 class="text-5xl sm:text-6xl font-extrabold mb-6 text-purple-800 glow-text">Smarter Community Management, Simplified</h1>
    <p class="text-lg sm:text-xl text-slate-700 mb-8">Automate tasks, empower your members, and unlock insights with a secure, beautiful dashboard.</p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="#pricing" class="btn-primary px-8 py-4 rounded-xl font-bold shadow-lg">View Plans</a>
      <button onclick="openModal('videoModal')" class="btn-secondary px-8 py-4 rounded-xl font-medium">Watch Demo</button>
    </div>
  </div>
  <div class="mt-12 glass p-6 rounded-2xl shadow-lg max-w-4xl w-full">
    <div class="aspect-video bg-purple-100 rounded-xl flex items-center justify-center text-purple-500 font-bold text-lg">
      Dashboard Preview
    </div>
  </div>
</section>

<!-- Features Grid -->
<section id="features" class="py-24 bg-white/60">
  <div class="max-w-6xl mx-auto px-6 text-center">
    <h2 class="text-4xl font-bold mb-16 text-purple-800">Everything You Need</h2>
    <div class="grid md:grid-cols-2 gap-8">
      <div class="glass p-8 rounded-2xl">
        <h3 class="text-2xl font-semibold mb-3 text-purple-800">⚡ Instant Setup</h3>
        <p class="text-slate-700">Connect your group in seconds and get started with zero hassle.</p>
      </div>
      <div class="glass p-8 rounded-2xl">
        <h3 class="text-2xl font-semibold mb-3 text-purple-800">🔒 Secure & Reliable</h3>
        <p class="text-slate-700">Enterprise-grade integrations ensure your data and actions are safe.</p>
      </div>
      <div class="glass p-8 rounded-2xl">
        <h3 class="text-2xl font-semibold mb-3 text-purple-800">📊 Analytics That Matter</h3>
        <p class="text-slate-700">Track growth, activity, and trends with clear, actionable visuals.</p>
      </div>
      <div class="glass p-8 rounded-2xl">
        <h3 class="text-2xl font-semibold mb-3 text-purple-800">🤖 Automation at Scale</h3>
        <p class="text-slate-700">Eliminate repetitive work by automating promotions, logs, and more.</p>
      </div>
    </div>
  </div>
</section>

<!-- Pricing -->
<section id="pricing" class="py-24 bg-gradient-to-tr from-purple-50 via-white to-purple-100">
  <div class="max-w-7xl mx-auto px-6 text-center">
    <h2 class="text-4xl font-bold mb-16 text-purple-800">Flexible Pricing, Clear Value</h2>
    <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
      <!-- Starter -->
      <div class="glass p-8 rounded-2xl">
        <h3 class="text-2xl font-semibold mb-4">Starter</h3>
        <p class="text-4xl font-bold mb-4">£0<span class="text-lg">/mo</span></p>
        <ul class="list-disc list-inside text-left space-y-2 text-slate-700">
          <li>1 Workspace</li>
          <li>1,000 members (extra 100 robux per 1k)</li>
          <li>Basic API, Roles, Docs, Logbook</li>
          <li>1 Application Center</li>
          <li>Optional Auto-Ranking (125 robux fee)</li>
        </ul>
        <button class="btn-secondary mt-6 px-6 py-3 rounded-lg">Unavailable</button>
      </div>
      <!-- Pro -->
      <div class="glass p-8 rounded-2xl border-2 border-purple-500 scale-105">
        <h3 class="text-2xl font-semibold mb-4">Pro</h3>
        <p class="text-4xl font-bold mb-4">400 robux<span class="text-lg">/mo</span></p>
        <ul class="list-disc list-inside text-left space-y-2 text-slate-700">
          <li>Everything in Starter</li>
          <li>3 Workspaces</li>
          <li>3,000 members/workspace (extra 50 per 1k)</li>
          <li>Advanced Graphs</li>
          <li>Enhanced API</li>
          <li>Auto-Ranking Included</li>
          <li>2 Application Centers</li>
          <li>1 Ranking Center</li>
          <li>Optional Auto-Ranking (125 robux fee)</li>
        </ul>
        <button class="btn-primary mt-6 px-6 py-3 rounded-lg">Unavailable</button>
      </div>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="py-24 text-center">
  <div class="max-w-3xl mx-auto px-6">
    <h2 class="text-4xl font-bold mb-6 text-purple-800">
      Ready to simplify your community management?
    </h2>
    <p class="text-lg mb-8 text-slate-700">
      Join Keylo today and take the pain out of running your group.
    </p>
    <a href="/register" class="btn-primary px-8 py-4 rounded-xl font-bold shadow-lg inline-block">
      Get Started
    </a>
  </div>
</section>

<!-- Footer -->
<footer id="contact" class="bg-gradient-to-br from-purple-900 via-purple-800 to-purple-700 text-white py-8">
  <div class="max-w-7xl mx-auto px-6 grid md:grid-cols-3 gap-8">
    <div>
      <h4 class="font-semibold mb-3">Keylo</h4>
      <p class="text-sm">Streamline your community operations with ease and security.</p>
    </div>
    <div>
      <h4 class="font-semibold mb-3">Links</h4>
      <ul class="space-y-2 text-sm">
        <li><a href="#features" class="hover:text-purple-200">Features</a></li>
        <li><a href="#pricing" class="hover:text-purple-200">Pricing</a></li>
      </ul>
    </div>
    <div>
      <h4 class="font-semibold mb-3">Support</h4>
      <ul class="space-y-2 text-sm">
        <li><a href="mailto:support@keyloroblox.xyz" class="hover:text-purple-200">support@keyloroblox.xyz</a></li>
        <li><a href="#" class="hover:text-purple-200">Discord Tickets</a></li>
      </ul>
    </div>
  </div>
  <div class="text-center mt-8 text-sm text-purple-200">© <%= new Date().getFullYear() %> Keylo. All rights reserved.</div>
</footer>

<!-- Video Modal -->
<div id="videoModal" class="fixed inset-0 bg-black/80 hidden items-center justify-center p-4 z-50">
  <div class="glass max-w-3xl w-full relative">
    <button onclick="closeModal('videoModal')" class="absolute top-3 right-3 text-slate-800 hover:text-black">✕</button>
    <div class="p-6">
      <h3 class="text-2xl font-bold mb-4 text-center text-purple-800 glow-text">Watch Our Demo</h3>
      <div class="aspect-video">
        <iframe src="https://www.youtube.com/embed/dQw4w9WgXcQ" class="w-full h-full rounded-xl" frameborder="0" allowfullscreen></iframe>
      </div>
    </div>
  </div>
</div>

<script>
function openModal(id){ document.getElementById(id).style.display='flex'; }
function closeModal(id){ document.getElementById(id).style.display='none'; }
</script>
<script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>
<script> lucide.createIcons(); </script>
</body>
</html>
