<script
  src="https://cdn.opencom.dev/widget.js"
  data-opencom-convex-url="https://outstanding-stork-558.eu-west-1.convex.cloud"
  data-opencom-workspace-id="vd79m4f3t6jkhyqdfyhsj9m26s848ye6"
  data-opencom-track-page-views="true"
></script>

  <script>
    document.getElementById('year').textContent = new Date().getFullYear();

    function openModal(id) {
      document.getElementById(id).classList.remove("hidden");
      document.getElementById(id).classList.add("flex");
      document.body.style.overflow = 'hidden';
    }
    function closeModal(id) {
      document.getElementById(id).classList.add("hidden");
      document.getElementById(id).classList.remove("flex");
      document.body.style.overflow = 'auto';
    }

    const counters = document.querySelectorAll('.counter');
    counters.forEach(counter => {
      counter.innerText = '0';
      const updateCounter = () => {
        const target = +counter.getAttribute('data-target');
        const count = +counter.innerText;
        const increment = target / 60;
        if (count < target) {
          counter.innerText = (count + increment).toFixed(target % 1 !== 0 ? 1 : 0);
          setTimeout(updateCounter, 20);
        } else {
          counter.innerText = target;
        }
      }
      setTimeout(updateCounter, 500); 
    });
  </script>

  <script src="https://unpkg.com/aos@next/dist/aos.js"></script>
