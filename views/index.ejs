<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Keylo</title>

<script src="https://cdn.tailwindcss.com"></script>
<link href="https://unpkg.com/aos@next/dist/aos.css" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

<style>

body{
font-family:'Inter',sans-serif;
background:#0f1117;
color:#e5e7eb;
}

/* navbar */

.navbar{
backdrop-filter:blur(14px);
background:rgba(15,17,23,.8);
border-bottom:1px solid rgba(255,255,255,.06);
}

/* buttons */

.btn-primary{
background:#4f46e5;
color:white;
padding:.7rem 1.6rem;
border-radius:.6rem;
font-weight:600;
transition:.25s;
}

.btn-primary:hover{
background:#4338ca;
transform:translateY(-2px);
}

.btn-outline{
border:1px solid rgba(255,255,255,.15);
padding:.7rem 1.6rem;
border-radius:.6rem;
transition:.25s;
}

.btn-outline:hover{
background:rgba(255,255,255,.05);
}

/* cards */

.card{
background:#151821;
border:1px solid rgba(255,255,255,.05);
border-radius:1rem;
transition:.25s;
}

.card:hover{
transform:translateY(-4px);
border-color:rgba(255,255,255,.12);
}

/* hero gradient */

.hero-gradient{
background:linear-gradient(
180deg,
rgba(79,70,229,.15),
rgba(15,17,23,0)
);
}

</style>
</head>

<body>

<!-- NAVBAR -->

<header class="navbar fixed top-0 w-full z-50">
<div class="max-w-7xl mx-auto px-8 py-4 flex justify-between items-center">

<div class="font-bold text-xl">Keylo</div>

<nav class="hidden md:flex gap-8 text-sm text-gray-400">
<a href="#features" class="hover:text-white">Features</a>
<a href="#pricing" class="hover:text-white">Pricing</a>
<a href="#contact" class="hover:text-white">Contact</a>
</nav>

<div class="flex gap-3">
<a href="/login" class="btn-outline">Login</a>
<a href="/register" class="btn-primary">Get Started</a>
</div>

</div>
</header>


<!-- HERO -->

<section class="hero-gradient pt-40 pb-28">

<div class="max-w-7xl mx-auto px-8 grid lg:grid-cols-2 gap-16 items-center">

<div data-aos="fade-right">

<h1 class="text-5xl lg:text-6xl font-extrabold leading-tight text-white">
Master Your Community
</h1>

<p class="text-gray-400 mt-5 text-lg max-w-lg">
Powerful tools for Roblox group management, analytics, and automation — all in one modern dashboard.
</p>

<div class="flex gap-4 mt-7">
<a href="#pricing" class="btn-primary">View Plans</a>
<a href="#features" class="btn-outline">Learn More</a>
</div>

</div>


<!-- DASHBOARD PREVIEW -->

<div data-aos="fade-left">

<img
src="/icons/dashprev.png"
alt="Dashboard Preview"
class="rounded-xl shadow-2xl border border-gray-800 hover:scale-[1.02] transition duration-500"
/>

</div>

</div>

</section>


<!-- METRICS -->

<section class="py-20 border-t border-gray-800">

<div class="max-w-6xl mx-auto px-8 grid grid-cols-2 md:grid-cols-4 gap-10 text-center">

<div data-aos="fade-up">
<div class="text-3xl font-bold text-white">1,000+</div>
<p class="text-gray-400 mt-2 text-sm">Groups Managed</p>
</div>

<div data-aos="fade-up" data-aos-delay="100">
<div class="text-3xl font-bold text-white">50K+</div>
<p class="text-gray-400 mt-2 text-sm">Members Tracked</p>
</div>

<div data-aos="fade-up" data-aos-delay="200">
<div class="text-3xl font-bold text-white">120+</div>
<p class="text-gray-400 mt-2 text-sm">Automations</p>
</div>

<div data-aos="fade-up" data-aos-delay="300">
<div class="text-3xl font-bold text-white">24/7</div>
<p class="text-gray-400 mt-2 text-sm">Support</p>
</div>

</div>

</section>


<!-- FEATURES -->

<section id="features" class="py-24 border-t border-gray-800">

<div class="max-w-6xl mx-auto px-8">

<h2 class="text-4xl font-bold text-center mb-16 text-white" data-aos="fade-up">
Everything You Need
</h2>

<div class="grid md:grid-cols-2 gap-10">

<div class="card p-8" data-aos="fade-up">
<h3 class="text-xl font-semibold text-white">Instant Setup</h3>
<p class="text-gray-400 mt-2">Connect your Roblox group and start managing within seconds.</p>
</div>

<div class="card p-8" data-aos="fade-up" data-aos-delay="100">
<h3 class="text-xl font-semibold text-white">Secure Infrastructure</h3>
<p class="text-gray-400 mt-2">Enterprise-grade protection and stable API integrations.</p>
</div>

<div class="card p-8" data-aos="fade-up" data-aos-delay="200">
<h3 class="text-xl font-semibold text-white">Advanced Analytics</h3>
<p class="text-gray-400 mt-2">Understand growth, activity, and engagement across your community.</p>
</div>

<div class="card p-8" data-aos="fade-up" data-aos-delay="300">
<h3 class="text-xl font-semibold text-white">Automation Tools</h3>
<p class="text-gray-400 mt-2">Reduce manual moderation with powerful automated workflows.</p>
</div>

</div>

</div>

</section>


<!-- PRICING -->

<section id="pricing" class="py-24 border-t border-gray-800">

<div class="max-w-5xl mx-auto px-8 text-center">

<h2 class="text-4xl font-bold text-white mb-14" data-aos="fade-up">
Simple Pricing
</h2>

<div class="grid md:grid-cols-2 gap-10">

<div class="card p-10" data-aos="fade-right">

<h3 class="text-xl font-semibold text-white mb-4">Starter</h3>

<p class="text-4xl font-bold text-white">Free</p>

<ul class="text-gray-400 text-sm mt-6 space-y-2">
<li>1 Workspace</li>
<li>Basic Analytics</li>
<li>API Access</li>
</ul>

<button class="btn-outline w-full mt-7 opacity-50 cursor-not-allowed">
Unavailable
</button>

</div>


<div class="card p-10" data-aos="fade-left">

<h3 class="text-xl font-semibold text-white mb-4">Pro</h3>

<p class="text-4xl font-bold text-white">400 Robux</p>

<ul class="text-gray-400 text-sm mt-6 space-y-2">
<li>3 Workspaces</li>
<li>Advanced Analytics</li>
<li>Automation Tools</li>
<li>Priority Support</li>
</ul>

<button class="btn-primary w-full mt-7">
Unavailable
</button>

</div>

</div>

</div>

</section>


<!-- CTA -->

<section class="py-20 border-t border-gray-800 text-center">

<h2 class="text-4xl font-bold text-white mb-4" data-aos="zoom-in">
Simplify Your Workflow
</h2>

<p class="text-gray-400 mb-6" data-aos="zoom-in" data-aos-delay="100">
Upgrade your Roblox community management today.
</p>

<a href="/register" class="btn-primary" data-aos="zoom-in" data-aos-delay="200">
Get Started
</a>

</section>


<!-- FOOTER -->

<footer id="contact" class="border-t border-gray-800 py-12 text-gray-400 text-sm">

<div class="max-w-7xl mx-auto px-8 grid md:grid-cols-4 gap-10">

<div>
<h4 class="text-white font-semibold mb-3">Product</h4>
<p>Features</p>
<p>Pricing</p>
</div>

<div>
<h4 class="text-white font-semibold mb-3">Company</h4>
<p>About</p>
<p>Careers</p>
</div>

<div>
<h4 class="text-white font-semibold mb-3">Support</h4>
<p>team@keylogroup.co.uk</p>
<p>Discord Tickets</p>
</div>

<div>
<h4 class="text-white font-semibold mb-3">Legal</h4>
<p>Privacy Policy</p>
<p>Terms of Service</p>
</div>

</div>

<div class="text-center text-gray-500 mt-10">
© <%= new Date().getFullYear() %> Keylo
</div>

</footer>


<script src="https://unpkg.com/aos@next/dist/aos.js"></script>
<script>
AOS.init({
duration:700,
easing:"ease-out-cubic",
once:false,
mirror:true
});
</script>

</body>
</html>
