<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Keylo — Register</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&family=Outfit:wght@600;800&display=swap" rel="stylesheet">
  <style>
    body {
      background-color: #0d0d0d;
      color: #fff;
      font-family: 'Inter', sans-serif;
      min-height: 100vh;
      min-width: 100vw;
      margin: 0;
      padding: 0;
      overflow-x: hidden;
      position: relative;
    }
    .dotted-bg {
      position: fixed;
      inset: 0;
      background-image: radial-gradient(#222 1px, transparent 1px);
      background-size: 24px 24px;
      z-index: 0;
    }
    .dotted-bg::before {
      content: "";
      position: absolute;
      inset: 0;
      background: radial-gradient(#1a1a1a 1px, transparent 1px);
      background-size: 24px 24px;
      opacity: 0.5;
      pointer-events: none;
    }
    .glass {
      background: rgba(24, 24, 24, 0.7);
      backdrop-filter: blur(14px);
      border-radius: 22px;
      border: 1px solid #222;
      box-shadow: 0 8px 30px rgba(0,0,0,0.28);
      z-index: 1;
      padding: 2rem;
    }
    .btn-primary {
      background: linear-gradient(to right, #4f46e5, #6366f1);
      color: white;
      transition: background 0.18s, transform .14s;
      border-radius: 0.75rem;
      font-weight: 600;
      box-shadow: 0 2px 12px 0 #15151560;
      outline: none;
      border: none;
    }
    .btn-primary:hover, .btn-primary:focus {
      background: linear-gradient(to right, #3730a3, #6366f1);
      transform: translateY(-1px) scale(1.02);
    }
    .glow-text {
      text-shadow: 0 0 7px rgba(128, 90, 255, 0.44);
    }
    input, .username-display {
      background: rgba(24,24,24,0.7);
      color: #fff;
      border: 1px solid rgba(255,255,255,0.18);
      border-radius: 12px;
      padding: 0.75rem;
      width: 100%;
      outline: none;
      transition: border 0.2s, box-shadow 0.2s, background 0.2s;
      margin-bottom: 0.5rem;
    }
    input:focus {
      border-color: #6366f1;
      box-shadow: 0 0 0 2px rgba(99, 102, 241, 0.3);
      background: rgba(40,40,60,0.88);
    }
    .username-display {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 0.75rem;
      cursor: default;
      user-select: none;
    }
    .username-display img {
      width: 40px;
      height: 40px;
      border-radius: 9999px;
      border: 1px solid rgba(255,255,255,0.3);
    }
    @media (max-width: 600px) {
      .glass { padding: 1.2rem 0.6rem !important; }
    }
  </style>
</head>
<body class="min-h-screen flex items-center justify-center px-4 relative">
<div class="dotted-bg"></div>

<div class="glass max-w-md w-full mx-auto z-10">
  <h2 class="text-4xl font-extrabold text-center mb-8 glow-text">Register</h2>

  <div id="step4">
    <form method="POST" action="/api/register">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">

      <!-- Hidden Roblox username field -->
      <input type="hidden" name="robloxUsername" value="<%= robloxUsername %>">

      <!-- Username display -->
      <label class="block text-sm font-medium text-gray-300 mb-2">Username</label>
      <div class="username-display mb-4">
        <img src="<%= avatarUrl %>" alt="Avatar">
        <span class="font-semibold text-white"><%= robloxUsername %></span>
      </div>

      <!-- Password -->
      <label for="password" class="block text-sm font-medium text-gray-300 mb-2">Password</label>
      <input 
        name="password" 
        type="password" 
        placeholder="Enter your password" 
        required
        autocomplete="new-password"
        class="mb-4"
      >

      <button type="submit" class="btn-primary w-full py-3 mt-2 rounded-lg font-semibold">Finish Registration</button>
    </form>
  </div>
</div>
</body>
</html>
