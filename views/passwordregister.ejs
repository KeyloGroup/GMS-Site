<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Keylo — Register</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&family=Outfit:wght@600;800&display=swap" rel="stylesheet">
  <style>
    body {
      background: radial-gradient(circle at 70% 50%, rgba(0, 51, 153, 0.5), rgba(0, 0, 0, 0.9) 70%),
                  linear-gradient(135deg, rgba(0, 0, 64, 0.8), rgba(0, 0, 0, 0.95));
      color: #fff;
      font-family: 'Inter', sans-serif;
      transition: background 0.3s ease, color 0.3s ease;
    }
    h1, h2, h3, h4 { font-family: 'Outfit', sans-serif; }

    .glass {
      background: rgba(255, 255, 255, 0.05);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 22px;
      padding: 2rem;
    }

    .btn-primary {
      background: linear-gradient(to right, #2563eb, #1d4ed8);
      color: white;
      transition: all 0.3s ease;
    }
    .btn-primary:hover { background: linear-gradient(to right, #1e40af, #1d4ed8); }

    .glow-text { text-shadow: 0 0 6px rgba(60, 100, 255, 0.4); }

    label {
      display: block;
      margin-bottom: 0.5rem;
      color: #aaa;
    }

    input, .username-display {
      background: rgba(255, 255, 255, 0.05);
      color: #fff;
      border: 1px solid rgba(255, 255, 255, 0.2);
      border-radius: 12px;
      padding: 0.75rem;
      width: 100%;
      outline: none;
      transition: all 0.2s ease;
    }

    input:focus {
      border-color: #2563eb;
      box-shadow: 0 0 0 2px rgba(37, 99, 235, 0.3);
    }

    .username-display {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 0.75rem;
      cursor: default;
      user-select: none;
    }

    .username-display img {
      width: 40px;
      height: 40px;
      border-radius: 9999px;
      border: 1px solid rgba(255,255,255,0.3);
    }
  </style>
</head>
<body class="min-h-screen flex items-center justify-center px-4">

<div class="glass max-w-md w-full">
  <h2 class="text-4xl font-extrabold text-center mb-8 glow-text">Register</h2>

  <div id="step4">
<form method="POST" action="/api/register">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>">

  <!-- Hidden Roblox username field -->
  <input type="hidden" name="robloxUsername" value="<%= robloxUsername %>">

  <!-- Username display -->
  <label class="mb-2 text-gray-400">Username</label>
  <div class="username-display mb-4">
    <img src="<%= avatarUrl %>" alt="Avatar">
    <span class="font-semibold text-white"><%= robloxUsername %></span>
  </div>

  <!-- Password -->
  <label for="password" class="text-gray-400">Password</label>
  <input 
    name="password" 
    type="password" 
    placeholder="Enter your password" 
    required
    class="mb-6"
  >

  <button type="submit" class="btn-primary w-full py-3 rounded-lg font-semibold">Finish Registration</button>
</form>
  </div>
</div>

</body>
</html>
